<clickhouse>
    <!-- Allow path-style HTTP requests (`/database/table.format`, hive-style filters, etc.) to be
         routed to the query handler. This server-level flag is the global routing gate; the per-user
         `http_allow_database_as_path` / `http_allow_table_as_file` / `http_allow_filters_as_path`
         settings (enabled in the default profile by `users.d/http_paths.xml`) then control whether a
         routed path is actually interpreted. Enabled here so the `04245` test can exercise it. -->
    <http_allow_path_requests>1</http_allow_path_requests>

    <!-- A dynamic-query handler mounted under `/api/v1`. The handler strips the prefix
         before parsing the remaining URL path for database/table/format/compression/filters.

         The element is named `rule_api_v1` instead of `rule` so it does not collide with the
         `<rule>` element in `handlers.yaml` (which configures the `/upyachka` redirect for the
         02998 test). The factory accepts any element name that starts with `rule`. -->
    <http_handlers>
        <rule_api_v1>
            <url_prefix>/api/v1</url_prefix>
            <handler>
                <type>dynamic_query_handler</type>
            </handler>
        </rule_api_v1>
    </http_handlers>
</clickhouse>
