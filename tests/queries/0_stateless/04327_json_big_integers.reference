-- Normal integers still work correctly
{"a":42}	42
{"a":-42}	-42
{"a":18446744073709551615}	18446744073709551615
{"a":9223372036854775807}	9223372036854775807
-- Big integers coerced to smaller types that can hold them
{"a":18446744073709551616}	18446744073709551616
-- Mixed document: normal and big integers together
{"a":42,"b":123456789123456789123456789}	42	123456789123456789123456789
-- Big integers in arrays
{"a":[123456789123456789123456789,987654321987654321987654321]}	[123456789123456789123456789,987654321987654321987654321]
