123456789123456789123456789
-123456789123456789123456789
-- Big integer into String (should work, stored as string)
{"a":"123456789123456789123456789"}	123456789123456789123456789
-- Untyped path: big integer inferred as String in dynamic JSON
{"a":"123456789123456789123456789"}	123456789123456789123456789	String
