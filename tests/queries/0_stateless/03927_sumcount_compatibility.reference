SET allow_suspicious_low_cardinality_types = 1;
SELECT
    toTypeName(sumCount(NULL)),
    sumCount(NULL);
Nullable(Nothing)	\N
SELECT
    toTypeName(sumCount(CAST(NULL, 'Nullable(Float32)'))),
    sumCount(CAST(NULL, 'Nullable(Float32)'));
Tuple(Float64, UInt64)	(0,0)
SELECT
    toTypeName(sumCount(CAST(NULL, 'LowCardinality(Nullable(Float32))'))),
    sumCount(CAST(NULL, 'LowCardinality(Nullable(Float32))'));
Tuple(Float64, UInt64)	(0,0)
SELECT hex(sumCountState(CAST(NULL, 'Nullable(Float32)')));
000000000000000000
SELECT hex(sumCountState(CAST(NULL, 'LowCardinality(Nullable(Float32))')));
000000000000000000
SELECT sumCount(x), hex(sumCountState(x))
FROM
(
    SELECT CAST(arrayJoin([NULL, NULL, NULL]), 'Nullable(Float32)') AS x
);
(0,0)	000000000000000000
