SELECT *
FROM
(
    SELECT number
    FROM numbers(_CAST(15, \'UInt64\'))
    WHERE number > 10
) AS `04105_pv`
SELECT *
FROM
(
    SELECT number
    FROM numbers(_CAST(20, \'UInt64\'))
    WHERE number > _CAST(5, \'UInt64\')
) AS `04105_pv_multi`
SELECT *
FROM
(
    SELECT number
    FROM
    (
        SELECT number
        FROM numbers(_CAST(5, \'UInt64\'))
    ) AS `04105_pv_nested_inner`
    WHERE number > 0
) AS `04105_pv_nested_outer`
SELECT *
FROM `04105_plain_view`
SELECT *
FROM
(
    SELECT number
    FROM
    (
        SELECT number
        FROM numbers(_CAST(12, \'UInt64\'))
        WHERE number > 10
    ) AS `04105_pv`
)
