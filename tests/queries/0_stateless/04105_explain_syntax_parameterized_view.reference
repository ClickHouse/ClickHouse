SELECT *
FROM
(
    SELECT number
    FROM numbers(_CAST(15, \'UInt64\'))
    WHERE greater(number, 10)
) AS `04105_pv`
SELECT *
FROM
(
    SELECT number
    FROM numbers(_CAST(20, \'UInt64\'))
    WHERE greater(number, _CAST(5, \'UInt64\'))
) AS `04105_pv_multi`
SELECT *
FROM
(
    SELECT number
    FROM
    (
        SELECT number
        FROM numbers(_CAST(5, \'UInt64\'))
    ) AS `04105_pv_nested_inner`
    WHERE greater(number, 0)
) AS `04105_pv_nested_outer`
SELECT *
FROM `04105_plain_view`
SELECT *
FROM
(
    SELECT number
    FROM
    (
        SELECT number
        FROM numbers(_CAST(12, \'UInt64\'))
        WHERE greater(number, 10)
    ) AS `04105_pv`
)
SELECT *
FROM `04105_join_target`
ALL INNER JOIN
(
    SELECT number
    FROM numbers(_CAST(10, \'UInt64\'))
    WHERE greater(number, 10)
) AS `04105_pv` USING (number)
SELECT t.number
FROM
(
    SELECT number
    FROM numbers(_CAST(10, \'UInt64\'))
    WHERE greater(number, 10)
) AS t
SELECT *
FROM numbers(3)
SETTINGS allow_experimental_analyzer = 1
SELECT *
FROM `04105_modifiers_pv`(equals(n, 1))
FINAL
SELECT count()
FROM `04105_modifiers_pv`(equals(n, 1))
SAMPLE 5 / 10
SELECT *
FROM `04105_pv_security_none`(equals(n, 1))
SELECT *
FROM `04105_pv_security_definer`(equals(n, 1))
