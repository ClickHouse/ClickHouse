CHECK TABLE t
CHECK TABLE t PARTITION 1
CHECK TABLE t PART \'all_1_1_0\'
KILL QUERY WHERE 1 SYNC
KILL QUERY WHERE 1 ASYNC
KILL MUTATION WHERE 1 TEST
KILL PART_MOVE_TO_SHARD WHERE 1 TEST
SYSTEM DROP REPLICA \'r\' FROM ZKPATH \'/clickhouse/tables/foo\'
SYSTEM DROP REPLICA \'r\' FROM ZKPATH \'aux:/clickhouse/foo\'
ALTER TABLE t (MODIFY TTL d GROUP BY x SET y = max(y))
SELECT x FROM t ORDER BY x ASC WITH FILL INTERPOLATE (`x` AS x + 1)
SELECT count() FROM t GROUP BY GROUPING SETS ((a), (b))
CREATE VIEW v DEFINER = CURRENT_USER SQL SECURITY DEFINER AS SELECT 1
CREATE VIEW v DEFINER = u SQL SECURITY DEFINER AS SELECT 1
ALTER TABLE t (MODIFY COLUMN `x` REMOVE TTL)
ALTER TABLE t (MODIFY COLUMN `x` UInt16 FIRST )
SELECT a FROM t LIMIT 1 BY ALL
SELECT a FROM t ORDER BY a ASC LIMIT 1  WITH TIES
CREATE VIEW v DEFINER = CURRENT_USER SQL SECURITY DEFINER AS SELECT 1
CREATE MATERIALIZED VIEW v REFRESH DEPENDS ON src ENGINE = Memory AS SELECT 1
CREATE MATERIALIZED VIEW v REFRESH EVERY 1 HOUR OFFSET 30 MINUTE ENGINE = Memory AS SELECT 1
WITH RECURSIVE x AS (SELECT 1) SELECT 1
SELECT * FROM a CROSS JOIN b
SELECT * FROM a NATURAL LEFT JOIN b
SELECT * FROM a SEMI LEFT JOIN b ON a.x = b.y
ALTER TABLE t (ADD STATISTICS  a TYPE  tdigest)
ALTER TABLE t (DROP STATISTICS  a)
ALTER TABLE t (CLEAR STATISTICS  a IN PARTITION 1)
ALTER TABLE t (CLEAR COLUMN x IN PARTITION 1)
SELECT count() OVER (ORDER BY x ASC ROWS BETWEEN 1 PRECEDING AND CURRENT ROW)
SELECT count() FROM t GROUP BY a
INSERT INTO t SELECT 1
INSERT INTO db.t SELECT 1
INSERT INTO FUNCTION `null`(\'x UInt8\') SELECT 1 AS x
INSERT INTO FUNCTION file(\'data.parquet\') PARTITION BY x SELECT 1 AS x
