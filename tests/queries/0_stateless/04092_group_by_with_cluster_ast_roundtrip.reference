SELECT count()
FROM
(
    SELECT
        toUInt64(number) AS x,
        toUInt64(multiply(number, 2)) AS y
    FROM numbers(4)
)
GROUP BY tuple(x, y) WITH CLUSTER 1.
SELECT count()
FROM
(
    SELECT toUInt64(number) AS x
    FROM numbers(4)
)
GROUP BY x WITH CLUSTER 1.
SELECT count()
FROM
(
    SELECT
        toUInt64(1) AS k,
        toUInt64(2) AS x,
        toUInt64(3) AS y
    FROM system.one
)
GROUP BY
    k,
    tuple(x, y) WITH CLUSTER 1.
