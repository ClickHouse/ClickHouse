-- The `limit`/`offset` settings are a global cap on the whole result. For a top-level UNION ALL whose
-- branches use LIMIT AFTER/UNTIL, the cap must be applied once over the merged union result, not once
-- per branch (which would let two branches return up to 2*limit rows). The settings are moved off the
-- range branch nodes onto the UnionNode and applied as a single outer step after the union.

-- { echo }

-- Two range branches, settings limit = 2: the union result is capped to 2 (not 4).
(SELECT number AS n FROM numbers(5) LIMIT AFTER number >= 0) UNION ALL (SELECT number AS n FROM numbers(5) LIMIT AFTER number >= 0) SETTINGS limit = 2;
0
1
(SELECT number AS n FROM numbers(5) LIMIT AFTER number >= 0) UNION ALL (SELECT number AS n FROM numbers(5) LIMIT AFTER number >= 0) SETTINGS limit = 2, enable_analyzer = 0;
0
1
-- limit + offset applied once after the union.
(SELECT number AS n FROM numbers(5) ORDER BY n LIMIT AFTER number >= 0) UNION ALL (SELECT number AS n FROM numbers(5) ORDER BY n LIMIT AFTER number >= 0) SETTINGS limit = 2, offset = 1;
1
2
(SELECT number AS n FROM numbers(5) ORDER BY n LIMIT AFTER number >= 0) UNION ALL (SELECT number AS n FROM numbers(5) ORDER BY n LIMIT AFTER number >= 0) SETTINGS limit = 2, offset = 1, enable_analyzer = 0;
1
2
-- UNTIL branches, settings limit once.
(SELECT number AS n FROM numbers(5) LIMIT UNTIL number >= 3) UNION ALL (SELECT number AS n FROM numbers(5) LIMIT UNTIL number >= 3) SETTINGS limit = 2;
0
1
(SELECT number AS n FROM numbers(5) LIMIT UNTIL number >= 3) UNION ALL (SELECT number AS n FROM numbers(5) LIMIT UNTIL number >= 3) SETTINGS limit = 2, enable_analyzer = 0;
0
1
