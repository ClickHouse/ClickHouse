CREATE TABLE default.uk_t
(
    `id` UInt64,
    `user_id` UInt32,
    `v` String
)
ENGINE = MergeTree
ORDER BY (id, user_id)
UNIQUE KEY (id)
SETTINGS index_granularity = 8192
(id)
CREATE TABLE default.uk_t_rt
(
    `id` UInt64,
    `user_id` UInt32,
    `v` String
)
ENGINE = MergeTree
ORDER BY (id, user_id)
UNIQUE KEY (id)
SETTINGS index_granularity = 8192
(id)

2
CREATE TABLE default.uk_t_composite
(
    `id` UInt64,
    `sub` UInt32,
    `v` String
)
ENGINE = MergeTree
ORDER BY (id, sub)
UNIQUE KEY (id, sub)
SETTINGS index_granularity = 8192
CREATE TABLE default.uk_inline_pk
(
    `id` UInt64,
    `v` String
)
ENGINE = MergeTree
PRIMARY KEY tuple(id)
ORDER BY tuple(id)
UNIQUE KEY (id)
SETTINGS index_granularity = 8192
(id)
CREATE TABLE default.uk_ttl_inline_pk
(
    `c0` Int32,
    `ts` DateTime
)
ENGINE = MergeTree
PRIMARY KEY tuple(c0)
ORDER BY tuple(c0)
UNIQUE KEY (c0)
TTL ts + toIntervalDay(1)
SETTINGS index_granularity = 8192
CREATE TABLE default.uk_ttl_storage_pk
(
    `c0` Int32,
    `ts` DateTime
)
ENGINE = MergeTree
PRIMARY KEY (c0)
ORDER BY (c0)
UNIQUE KEY (c0)
TTL ts + toIntervalDay(1)
SETTINGS index_granularity = 8192
CREATE TABLE default.uk_ttl_full
(
    `c0` UInt32,
    `sk` UInt64,
    `ts` DateTime
)
ENGINE = MergeTree
PARTITION BY toDate(ts)
PRIMARY KEY (c0, sk)
ORDER BY (c0, sk)
UNIQUE KEY (c0)
SAMPLE BY sk
TTL ts + toIntervalDay(1)
SETTINGS index_granularity = 8192
