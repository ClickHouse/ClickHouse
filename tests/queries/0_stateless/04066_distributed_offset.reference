-- { echo }
SET enable_analyzer = 1;
SET prefer_localhost_replica = 1;
-- Positive OFFSET
SELECT count() FROM (SELECT number FROM remote('127.0.0.{1,2,3}', numbers_mt(10)) OFFSET 5);
25
SELECT count() FROM (SELECT number FROM remote('127.0.0.{1,2,3}', numbers_mt(10)) ORDER BY number OFFSET 5);
25
SELECT groupArray(number) FROM (SELECT number FROM remote('127.0.0.{1,2,3}', numbers_mt(10)) ORDER BY number OFFSET 5);
