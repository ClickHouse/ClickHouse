{"a":42}	{'a':42}
{"a":42,"b":"Hello"}	{'a':42,'b':'Hello'}
{"a":{"b":1}}	{'a.b':1}
{"a":[1,2,3]}	{'a':[1,2,3]}
{"a":42,"b":"x","c":3.14}	{'a':42,'b':'x','c':3.14}
{"a":42,"b":"Hi"}	{'a':'Int64','b':'String'}	{'a':42,'b':'Hi'}
{"a":{"b":{"c":42}}}	{'a.b.c':42}
{"a":true,"b":false}	{'a':true,'b':false}
{"arr":[{"x":1},{"y":2}]}	{'arr':['{"x":1}','{"y":2}']}
{"a":[[1,2],[3,4]]}	{'a':[[1,2],[3,4]]}
{"a":[1,{"b":2},3]}	{'a':[1,'{"b":2}',3]}
{"empty_arr":[]}	{'empty_arr':[]}
{"arr":[10,20],"b":true,"n":1,"nest":{"x":0},"s":"hi"}	{'arr':[10,20],'b':true,'n':1,'nest.x':0,'s':'hi'}
