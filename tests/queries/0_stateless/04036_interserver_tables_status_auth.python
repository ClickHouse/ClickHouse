#!/usr/bin/env python3
import os, socket

HOST = os.environ.get("CLICKHOUSE_HOST", "127.0.0.1")
PORT = int(os.environ.get("CLICKHOUSE_PORT_TCP", "9000"))
DB   = os.environ.get("CLICKHOUSE_DATABASE", "default")

def vu(n):
    b = bytearray()
    while n >= 0x80: b.append((n & 0x7F) | 0x80); n >>= 7
    b.append(n & 0x7F); return bytes(b)

def ws(s):
    b = s.encode() if isinstance(s, str) else bytes(s)
    return vu(len(b)) + b

def recv_exact(s, n):
    buf = bytearray()
    while len(buf) < n:
        chunk = s.recv(n - len(buf))
        if not chunk: raise EOFError()
        buf.extend(chunk)
    return buf

def read_vu(s):
    x = 0
    for i in range(9):
        b = recv_exact(s, 1)[0]
        x |= (b & 0x7F) << (7 * i)
        if not (b & 0x80): return x
    return x

def read_ws(s): return recv_exact(s, read_vu(s))

# Interserver Hello (revision 54449 — below optional-fields threshold 54461)
# cluster_name + salt are appended synchronously: processClusterNameAndSalt is
# called inside receiveHello before sendHello, so they must be in the same send.
hello = (vu(0) + ws("test") + vu(24) + vu(3) + vu(54449)
         + ws("") + ws(" INTERSERVER SECRET ") + ws("")
         + ws("") + ws(""))  # cluster_name + salt

# TablesStatusRequest (packet type 5): 1 table
tsr = vu(5) + vu(1) + ws(DB) + ws("t_interserver_auth_check")

sock = socket.socket()
sock.settimeout(5)
sock.connect((HOST, PORT))
try:
    sock.sendall(hello)
    # Consume server Hello: type + name + major + minor + revision + tz + display + patch
    assert read_vu(sock) == 0
    read_ws(sock); read_vu(sock); read_vu(sock); read_vu(sock)
    read_ws(sock); read_ws(sock); read_vu(sock)
    sock.sendall(tsr)
    data = sock.recv(4096)
    print("FAIL: server returned data" if data else "OK: connection closed without leaking table status")
except (EOFError, ConnectionResetError, socket.timeout):
    print("OK: connection closed without leaking table status")
finally:
    sock.close()
