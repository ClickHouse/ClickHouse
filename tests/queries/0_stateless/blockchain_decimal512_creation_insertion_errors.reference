CREATE TABLE default.test_decimal512_table\n(\n    `id` UInt32,\n    `token_balance` Decimal(154, 18),\n    `gas_fee` Decimal(154, 12),\n    `block_reward` Decimal(154, 6),\n    `transaction_amount` Decimal(154, 10) DEFAULT toDecimal512(\'1000.000000\', 6)\n)\nENGINE = Memory
CREATE TABLE default.test_decimal512_table\n(\n    `id` UInt32,\n    `token_balance` Decimal(154, 18),\n    `gas_fee` Decimal(154, 12),\n    `block_reward` Decimal(154, 6),\n    `transaction_amount` Decimal(76, 6) DEFAULT toDecimal512(\'1000.000000\', 6)\n)\nENGINE = Memory
CREATE TABLE default.test_decimal512_table\n(\n    `id` UInt32,\n    `token_balance` Decimal(154, 18),\n    `gas_fee` Decimal(154, 12),\n    `block_reward` Decimal(154, 6),\n    `transaction_amount` Decimal(154, 6) DEFAULT toDecimal512(\'1000.000000\', 6)\n)\nENGINE = Memory
