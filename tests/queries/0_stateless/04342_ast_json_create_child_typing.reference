CREATE TABLE t (`x` Tuple(UInt8, String)) ENGINE = Memory
CREATE TABLE t (`x` UInt8) ENGINE = MergeTree ORDER BY x SETTINGS index_granularity = 1
CREATE VIEW v AS SELECT 1
CREATE TABLE t (`x` UInt8) ENGINE = Memory COMMENT \'c\'
CREATE MATERIALIZED VIEW mv TO dst AS SELECT 1
