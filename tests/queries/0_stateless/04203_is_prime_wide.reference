0
SELECT isProbablePrime(toUInt128(18446744073709551557) * toUInt128(18446744073709551533));   -- product of two large UInt64 primes
0
SELECT isProbablePrime(toUInt128(2147483647) * toUInt128(2147483647));                       -- M_31^2
0
SELECT isProbablePrime(toUInt128(2147483647) * toUInt128(2305843009213693951));              -- M_31 * M_61
0
SELECT isProbablePrime(toUInt128(2305843009213693951) * toUInt128(2305843009213693951));     -- M_61^2
0
