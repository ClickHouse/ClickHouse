SELECT isProbablePrime(toUInt256('115792089210356248762697446949407573530086143415290314195533631308867097853951'));       -- NIST P-256 base field
1
SELECT isProbablePrime(toUInt256('115792089237316195423570985008687907853269984665640564039457584007913129639747'));       -- 2^256 - 189
