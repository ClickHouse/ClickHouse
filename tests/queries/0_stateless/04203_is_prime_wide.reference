-- { echo }

-- UInt128 primes (Mersenne primes that fit in UInt128, plus 2^128 - 159)
SELECT isProbablePrime(toUInt128('618970019642690137449562111'));               -- M_89
1
SELECT isProbablePrime(toUInt128('162259276829213363391578010288127'));         -- M_107
1
SELECT isProbablePrime(toUInt128('170141183460469231731687303715884105727'));   -- M_127
1
SELECT isProbablePrime(toUInt128('340282366920938463463374607431768211297'));   -- 2^128 - 159
1
