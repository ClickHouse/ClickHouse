Negative: IN with subquery - plan
SELECT
    __table1.color_id AS color_id,
    __table1.payload AS payload
FROM default.t AS __table1
WHERE dictGetString(\'colors\', \'name\', __table1.color_id) IN (
    SELECT \'red\' AS `\'red\'`
    FROM system.one AS __table1
)
ORDER BY
    __table1.color_id ASC,
    __table1.payload ASC
