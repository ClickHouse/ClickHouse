Negative: IN with table column - plan
SELECT
    __table1.color_id AS color_id,
    __table1.payload AS payload
FROM default.t AS __table1
WHERE if(_CAST(0, \'UInt8\'), _CAST(NULL, \'Nullable(UInt8)\'), has(array(CAST(__table1.payload, \'Nullable(String)\')), dictGetString(\'colors\', \'name\', __table1.color_id)))
ORDER BY
    __table1.color_id ASC,
    __table1.payload ASC
Negative: IN with table column
IN with composite key - plan
SELECT
    __table1.k1 AS k1,
    __table1.k2 AS k2,
    __table1.payload AS payload
FROM default.fact AS __table1
WHERE (__table1.k1, __table1.k2) IN (
    SELECT
        __table1.k1 AS k1,
        __table1.k2 AS k2
    FROM dictionary(\'dict_prices\') AS __table1
    WHERE __table1.tag IN (\'pro\', \'basic\')
)
ORDER BY
    __table1.k1 ASC,
    __table1.k2 ASC,
    __table1.payload ASC
IN with composite key
1	a	x
1	b	y
