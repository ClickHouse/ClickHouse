-- basic
c	Tuple(a UInt8, s String)	DEFAULT	tuple(defaultValueOfTypeName(\'UInt8\'), \'Hello\')
id	UInt8		
1	(0,'Hello')
-- nested tuple
Tuple(a UInt8, t Tuple(x String, y UInt8))	tuple(defaultValueOfTypeName(\'UInt8\'), tuple(\'q\', defaultValueOfTypeName(\'UInt8\')))
1	(5,('z',1))
2	(0,('q',0))
-- default referencing a column
Tuple(a UInt8, s String)	tuple(x, defaultValueOfTypeName(\'String\'))
(7,'')
-- constant expression default
Tuple(a UInt8, s String)	tuple(1 + 2, upper(\'hi\'))
(3,'HI')
-- errors
-- alter add column
Tuple(a UInt8, s String)	DEFAULT	tuple(defaultValueOfTypeName(\'UInt8\'), \'Hi\')
1	(0,'Hi')
-- alter modify column
Tuple(a UInt8, b UInt8)	DEFAULT	tuple(defaultValueOfTypeName(\'UInt8\'), 42)
1	(0,42)
-- alter errors
-- nullable tuple
Nullable(Tuple(a UInt8, s String))	DEFAULT	tuple(defaultValueOfTypeName(\'UInt8\'), \'Hi\')
1	(0,'Hi')
-- lambda parameter shadowing an element name
Tuple(x UInt8, y Array(UInt8))	tuple(defaultValueOfTypeName(\'UInt8\'), arrayMap(x -> (x + 1), [1, 2, 3]))
(0,[2,3,4])
-- lambda body free identifier colliding with an element name
