#!/usr/bin/env bash
# Shared settings for TPC-DS tests, derived from tests/benchmarks/tpc-ds/settings.json.
# See tests/benchmarks/tpc-ds/README.md for known issues and workaround details.

TPCDS_SETTINGS_JSON="$CURDIR/../../benchmarks/tpc-ds/settings.json"

# 1. --max_rows_to_read 0 because of https://github.com/ClickHouse/ClickHouse/issues/99937. Can be removed after the issue is closed.
# 2. TPC-DS tables use S3 web disk. Increase HTTP retries to avoid transient `No message received` errors (default is 10).
SETTINGS=(-m --max_rows_to_read 0 --http_max_tries 100)
_tpcds_output=$(jq -e -r '
    "--format", .format,
    (.settings | to_entries[] | "--\(.key)", (.value | tostring))
' "$TPCDS_SETTINGS_JSON")
readarray -t _tpcds_lines <<< "$_tpcds_output"
SETTINGS+=("${_tpcds_lines[@]}")

# Spill GROUP BY and joins above 2 GiB: caps peak memory for the heaviest TPC-DS
# queries (q10/q69 ~4 GiB at SF1) under the sanitizer per-test budget. A low
# threshold makes external aggregation/join dominate wall time on instrumented
# builds. Kept here, not in settings.json: tests/performance/tpc{ds,h}.xml read
# the same settings.json and must stay in-memory.
SETTINGS+=(
    --max_bytes_before_external_group_by 2147483648
    --max_bytes_before_external_join 2147483648
)

# Plan/result test, not a perf test: spilling to disk starts slowly, so the test-env
# estimated-time guard false-positives (TOO_SLOW) under sanitizer builds. Disable it.
SETTINGS+=(--max_estimated_execution_time 0)
