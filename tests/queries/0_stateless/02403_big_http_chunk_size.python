#!/usr/bin/env python3
import os
from socket import AF_INET, SOCK_STREAM, socket

EXCEPTION_CODE_HEADER = "X-ClickHouse-Exception-Code"
TRANSFER_ENCODING_HEADER = "Transfer-Encoding"
CONNECTION_HEADER = "Connection"
HTTP_STATUS_STRING = "HTTP status string"

INTERESTING_SET = set((EXCEPTION_CODE_HEADER, TRANSFER_ENCODING_HEADER, CONNECTION_HEADER, HTTP_STATUS_STRING))


def main():
    host = os.environ["CLICKHOUSE_HOST"]
    port = int(os.environ["CLICKHOUSE_PORT_HTTP"])

    sock = socket(AF_INET, SOCK_STREAM)
    sock.connect((host, port))
    sock.settimeout(60)
    s = "POST /?query=select+1 HTTP/1.1\r\n"
    s += "Host: %s\r\n" % host
    s += "Content-type: multipart/form-data; boundary=--b3f1zid8kqwy\r\n"
    s += "Transfer-encoding: chunked\r\n"
    s += "\r\n"
    s += "ffffffffffffffff"
    s += "\r\n"
    s += "X" * 100000
    sock.sendall(s.encode())
    data = ""
    while 1:
        data_part = sock.recv(10000).decode()
        if not data_part:
            break
        data += data_part
    sock.close()

    lines = data.splitlines()


    headers = []
    for x in lines:
        x = x.strip()
        if not x:
            continue

        if x.startswith("HTTP/1.1"):
            headers.append(("HTTP status string", x))

        tokens = x.split(":", 1)
        if len(tokens) < 2:
            continue
        key, val = tokens
        headers.append((key.strip(), val.strip()))

    for k, v in headers:
        if k in INTERESTING_SET:
            print(k, ":", v)


if __name__ == "__main__":
    main()
