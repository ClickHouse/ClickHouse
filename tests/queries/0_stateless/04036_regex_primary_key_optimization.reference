SELECT count() FROM test_regex_charclass WHERE match(id, '^(abc[)]1|abc[)]2)') SETTINGS force_primary_key = 1; -- {serverError INDEX_NOT_USED}
SELECT count() FROM test_regex_charclass WHERE match(id, '^(abc[(]1|abc[(]2)') SETTINGS force_primary_key = 1; -- {serverError INDEX_NOT_USED}
