-- 7. Non-equi predicate (eager must not fire)
Expression ((Project names + Projection))
  MergingAggregated
    GatherExchange
      Aggregating
        Expression (Before GROUP BY)
          JoinLogical (Broadcast HashJoin )
            Expression (Change column names to column identifiers)
              ReadFromMergeTree (ParallelRead default.t_events)
            Expression (Change column names to column identifiers)
              ReadFromMergeTree (ReplicatedRead default.t_sessions)
