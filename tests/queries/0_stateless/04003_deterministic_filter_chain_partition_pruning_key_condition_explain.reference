            Parts: 15/15
            Granules: 15/15
          Partition
            Keys:
              x
            Condition: (modulo(cityHash64(x), 5) in [4, +Inf))
            Parts: 4/15
            Granules: 4/15
          Ranges: 4
EXPLAIN indexes = 1
SELECT x FROM test_det_function WHERE cityHash64(x) % 5 < 3 ORDER BY x;
Expression (Project names)
  Sorting (Sorting for ORDER BY)
    Expression ((Before ORDER BY + Projection))
