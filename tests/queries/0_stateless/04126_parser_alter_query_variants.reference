--- MODIFY SQL SECURITY ---
ALTER TABLE db.t\n    (MODIFY DEFINER = CURRENT_USER SQL SECURITY DEFINER)
ALTER TABLE db.t\n    (MODIFY SQL SECURITY INVOKER)
ALTER TABLE db.t\n    (MODIFY SQL SECURITY NONE)
--- MODIFY DEFINER ---
ALTER TABLE db.t\n    (MODIFY DEFINER = CURRENT_USER SQL SECURITY DEFINER)
--- MODIFY REFRESH ---
ALTER TABLE db.t\n    (MODIFY\nREFRESH EVERY 1 MINUTE)
--- MODIFY COMMENT ---
ALTER TABLE db.t\n    (MODIFY COMMENT \'new comment\')
--- APPLY DELETED MASK ---
ALTER TABLE db.t\n    (APPLY DELETED MASK)
ALTER TABLE db.t\n    (APPLY DELETED MASK IN PARTITION ID \'20230101\')
ALTER TABLE db.t\n    (APPLY DELETED MASK IN PARTITION 1)
--- MOVE PARTITION ---
ALTER TABLE db.t\n    (MOVE PARTITION 1 TO DISK \'mydisk\')
ALTER TABLE db.t\n    (MOVE PARTITION 1 TO VOLUME \'myvol\')
ALTER TABLE db.t\n    (MOVE PARTITION 1 TO TABLE db.u)
ALTER TABLE db.t\n    (MOVE PART \'part_1_1_0\' TO DISK \'mydisk\')
--- FETCH / REPLACE / ATTACH PARTITION ---
ALTER TABLE db.t\n    (FETCH PARTITION 1 FROM \'/from\')
ALTER TABLE db.t\n    (FETCH PART \'x\' FROM \'/from\')
ALTER TABLE db.t\n    (REPLACE PARTITION 1 FROM db.u)
ALTER TABLE db.t\n    (ATTACH PARTITION 1 FROM db.u)
ALTER TABLE db.t\n    (ATTACH PART \'part_1_1_0\')
--- DROP/DETACH PARTITION variants ---
ALTER TABLE db.t\n    (DROP PARTITION 1)
ALTER TABLE db.t\n    (DROP DETACHED PARTITION 1)
ALTER TABLE db.t\n    (DROP PART \'part_1_1_0\')
ALTER TABLE db.t\n    (DETACH PARTITION 1)
ALTER TABLE db.t\n    (DETACH PART \'part_1_1_0\')
ALTER TABLE db.t\n    (FORGET PARTITION 1)
--- FREEZE / UNFREEZE ---
ALTER TABLE db.t\n    (FREEZE)
ALTER TABLE db.t\n    (FREEZE PARTITION 1)
ALTER TABLE db.t\n    (FREEZE PARTITION 1 WITH NAME \'snap\')
ALTER TABLE db.t\n    (UNFREEZE WITH NAME \'snap\')
ALTER TABLE db.t\n    (UNFREEZE PARTITION 1 WITH NAME \'snap\')
--- MODIFY / RESET SETTING ---
ALTER TABLE db.t\n    (MODIFY SETTING index_granularity = 128)
ALTER TABLE db.t\n    (MODIFY SETTING index_granularity = 128, max_parts_in_total = 1000)
ALTER TABLE db.t\n    (RESET SETTING index_granularity)
ALTER TABLE db.t\n    (RESET SETTING index_granularity, max_parts_in_total)
--- CLEAR COLUMN / CLEAR INDEX ---
ALTER TABLE db.t\n    (CLEAR COLUMN c IN PARTITION 1)
ALTER TABLE db.t\n    (CLEAR COLUMN IF EXISTS c IN PARTITION 1)
ALTER TABLE db.t\n    (CLEAR INDEX idx IN PARTITION 1)
ALTER TABLE db.t\n    (CLEAR INDEX IF EXISTS idx IN PARTITION 1)
--- MATERIALIZE INDEX / PROJECTION / STATISTICS / COLUMN ---
ALTER TABLE db.t\n    (MATERIALIZE INDEX idx)
ALTER TABLE db.t\n    (MATERIALIZE INDEX idx IN PARTITION 1)
ALTER TABLE db.t\n    (MATERIALIZE PROJECTION prj)
ALTER TABLE db.t\n    (MATERIALIZE STATISTICS c)
ALTER TABLE db.t\n    (MATERIALIZE COLUMN c)
--- ADD / DROP / CLEAR PROJECTION ---
ALTER TABLE db.t\n    (ADD PROJECTION prj\n    (\n        SELECT *\n        ORDER BY a\n    ))
ALTER TABLE db.t\n    (ADD PROJECTION IF NOT EXISTS prj\n    (\n        SELECT *\n        ORDER BY a\n    ))
ALTER TABLE db.t\n    (DROP PROJECTION prj)
ALTER TABLE db.t\n    (DROP PROJECTION IF EXISTS prj)
ALTER TABLE db.t\n    (CLEAR PROJECTION prj IN PARTITION 1)
--- RENAME / MODIFY COLUMN ---
ALTER TABLE db.t\n    (RENAME COLUMN a TO b)
ALTER TABLE db.t\n    (RENAME COLUMN IF EXISTS a TO b)
ALTER TABLE db.t\n    (MODIFY COLUMN `c` Int32)
ALTER TABLE db.t\n    (MODIFY COLUMN `c` Int32 DEFAULT 0)
ALTER TABLE db.t\n    (MODIFY COLUMN `c` REMOVE DEFAULT)
ALTER TABLE db.t\n    (MODIFY COLUMN `c` MODIFY SETTING min_compress_block_size = 1024)
ALTER TABLE db.t\n    (MODIFY COLUMN `c` RESET SETTING min_compress_block_size)
