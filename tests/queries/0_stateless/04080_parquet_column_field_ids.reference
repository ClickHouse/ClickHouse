== explicit overrides ==
-- field_ids --
a	10
b	20
c	30
-- values --
1	hello	42
== auto-assign ==
-- field_ids --
a	1
b	2
c	3
-- values --
1	hello	42
== mixed override + auto-assign ==
-- field_ids --
a	2
b	1
c	3
-- values --
1	hello	42
== default (no settings) ==
-- field_ids --
a	-
b	-
c	-
-- values --
1	hello	42
== nested auto-assign ==
-- field_ids --
a	1
a.element	2
b	3
b.s	4
b.i	5
c	6
c.key	7
c.value	8
-- values --
[1,2,3]	('hi',7)	{'k':1}
== nested overrides ==
-- field_ids --
a	1
a.element	100
b	2
b.s	200
b.i	3
-- values --
[1,2,3]	('hi',7)
