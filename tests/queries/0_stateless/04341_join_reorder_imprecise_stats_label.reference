-- no column statistics, use_statistics=1: estimation is imprecise --
Join: a[no_stats~1000] ⋈ b[no_stats~100]
ResultRows: ~~100
-- column statistics present, use_statistics=1: estimation is precise (no label) --
Join: a[1000] ⋈ b[100]
ResultRows: 100
-- mixed: one side without statistics: top join is imprecise --
Join: a[1000] ⋈ b[no_stats~100]
ResultRows: ~~100
-- use_statistics=0: index estimate is still labeled, it is not derived from column statistics --
Join: a[no_stats~1000] ⋈ b[no_stats~100]
ResultRows: ~~100
