SELECT x
FROM
(
    SELECT 1 AS x
)
WHERE (toString(rand()) LIKE \'%1%\') OR (toString(rand()) LIKE \'%2%\')
SETTINGS enable_analyzer = 0
QUERY id: 0
  PROJECTION COLUMNS
    x UInt8
  PROJECTION
    LIST id: 1, nodes: 1
      COLUMN id: 2, column_name: x, result_type: UInt8, source_id: 3
  JOIN TREE
    QUERY id: 3, alias: __table1, is_subquery: 1
      PROJECTION COLUMNS
        x UInt8
      PROJECTION
        LIST id: 4, nodes: 1
          CONSTANT id: 5, constant_value: UInt64_1, constant_value_type: UInt8
      JOIN TREE
        TABLE id: 6, alias: __table2, table_name: system.one
  WHERE
    FUNCTION id: 7, function_name: or, function_type: ordinary, result_type: UInt8
      ARGUMENTS
        LIST id: 8, nodes: 2
          FUNCTION id: 9, function_name: like, function_type: ordinary, result_type: UInt8
            ARGUMENTS
              LIST id: 10, nodes: 2
                FUNCTION id: 11, function_name: toString, function_type: ordinary, result_type: String
                  ARGUMENTS
                    LIST id: 12, nodes: 1
                      FUNCTION id: 13, function_name: rand, function_type: ordinary, result_type: UInt32
                CONSTANT id: 14, constant_value: \'%1%\', constant_value_type: String
          FUNCTION id: 15, function_name: like, function_type: ordinary, result_type: UInt8
            ARGUMENTS
              LIST id: 16, nodes: 2
                FUNCTION id: 17, function_name: toString, function_type: ordinary, result_type: String
                  ARGUMENTS
                    LIST id: 18, nodes: 1
                      FUNCTION id: 19, function_name: rand, function_type: ordinary, result_type: UInt32
                CONSTANT id: 20, constant_value: \'%2%\', constant_value_type: String
  SETTINGS enable_analyzer=1
SELECT s
FROM t_or_like_chain_nondet
WHERE multiSearchAny(s, [\'a\', \'b\']) OR false
SETTINGS enable_analyzer = 0
