INSERT INTO t1 (\n    (\n        SELECT 1\n    )\n    EXCEPT ALL\n    (\n        SELECT 2\n    )\n)\nINTERSECT\nSELECT 3
INSERT INTO t1 (\n    SELECT 1\n    INTERSECT\n    SELECT 2\n)\nEXCEPT ALL\n(\n    SELECT 3\n)
INSERT INTO t1 (\n    SELECT 1\n    UNION ALL\n    SELECT 2\n)\nINTERSECT\nSELECT 3
INSERT INTO t1 (\n    (\n        SELECT 1\n    )\n    EXCEPT ALL\n    (\n        SELECT 2\n    )\n)\nINTERSECT\nSELECT 3
INSERT INTO t1 (a, b, c) FORMAT Values
INSERT INTO t1 SELECT\n    1,\n    2,\n    3
INSERT INTO t1 SELECT\n    1,\n    2,\n    3
