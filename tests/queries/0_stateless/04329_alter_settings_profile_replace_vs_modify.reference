--- populated profile: several settings + an inherited profile ---
CREATE SETTINGS PROFILE `p` SETTINGS INHERIT `base`, max_execution_time = 10., max_memory_usage = 100000000
--- bare SETTINGS: replaces everything (other settings and the inherited profile are gone) ---
CREATE SETTINGS PROFILE `p` SETTINGS readonly = 1
--- MODIFY SETTINGS: changes one entry, keeps the rest and the inherited profile ---
CREATE SETTINGS PROFILE `p` SETTINGS INHERIT `base`, max_execution_time = 99., max_memory_usage = 100000000
--- ADD SETTINGS with constraints: keeps the rest ---
CREATE SETTINGS PROFILE `p` SETTINGS INHERIT `base`, max_execution_time = 99., max_memory_usage = 100000000, max_threads = 8 MIN 4 MAX 16 WRITABLE
--- DROP SETTINGS: removes one, keeps the rest ---
CREATE SETTINGS PROFILE `p` SETTINGS INHERIT `base`, max_execution_time = 99., max_threads = 8 MIN 4 MAX 16 WRITABLE
--- combined DROP + ADD in one statement ---
CREATE SETTINGS PROFILE `p` SETTINGS INHERIT `base`, max_threads = 8 MIN 4 MAX 16 WRITABLE, readonly = 1
