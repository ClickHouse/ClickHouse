ExplainQuery_AST	EXPLAIN AST SELECT 1
ExplainQuery_SYNTAX	EXPLAIN SYNTAX SELECT 1
ExplainQuery_PLAN	EXPLAIN SELECT 1
TableExpression	SELECT 1 FROM t
TableJoin_INNER	SELECT a FROM t1 INNER JOIN t2 ON t1.id = t2.id
