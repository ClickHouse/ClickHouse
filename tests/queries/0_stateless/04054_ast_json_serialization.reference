ColumnsReplaceTransformer	SELECT * REPLACE (a + 1 AS a) FROM t
QualifiedColumnsRegexpMatcher	SELECT t.COLUMNS(\'x.*\') FROM t
QualifiedColumnsListMatcher	SELECT t.COLUMNS(a, b) FROM t
SelectQuery_full	SELECT DISTINCT a, sum(b) AS s FROM t PREWHERE c > 0 WHERE d = 1 GROUP BY a WITH TOTALS HAVING s > 10 ORDER BY s DESC LIMIT 5 BY a LIMIT 2, 10
