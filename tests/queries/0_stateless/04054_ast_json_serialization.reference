TTLElement	CREATE TABLE t (`a` UInt64, `d` DateTime) ENGINE = MergeTree ORDER BY a TTL d + toIntervalDay(1)
Partition	CREATE TABLE t (`a` UInt64, `d` Date) ENGINE = MergeTree PARTITION BY d ORDER BY a
CreateQuery_AS_SELECT	CREATE TABLE t ENGINE = MergeTree ORDER BY a AS SELECT 1 AS a
