ArrayJoin	SELECT x FROM t ARRAY JOIN arr AS x
ArrayJoin_LEFT	SELECT x FROM t LEFT ARRAY JOIN arr AS x
OrderByElement	SELECT a FROM t ORDER BY a ASC NULLS FIRST, b DESC NULLS LAST
OrderByElement_FILL	SELECT a FROM t ORDER BY a ASC WITH FILL FROM 1 TO 10 STEP 1
WindowDefinition	SELECT row_number() OVER (PARTITION BY a ORDER BY b ASC ROWS BETWEEN UNBOUNDED PRECEDING AND CURRENT ROW) FROM t
WindowListElement	SELECT row_number() OVER w FROM t WINDOW w AS (PARTITION BY a ORDER BY b ASC)
