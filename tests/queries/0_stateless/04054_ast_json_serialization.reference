RT_select	SELECT 1
RT_select_full	SELECT DISTINCT a, sum(b) AS s FROM t PREWHERE c > 0 WHERE d = 1 GROUP BY a WITH TOTALS HAVING s > 10 ORDER BY s DESC LIMIT 5 BY a LIMIT 2, 10
RT_union	SELECT 1 UNION ALL SELECT 2 UNION ALL SELECT 3
RT_union_distinct	SELECT 1 UNION DISTINCT SELECT 1
RT_intersect	SELECT 1 INTERSECT SELECT 1
RT_except	(SELECT 1) EXCEPT (SELECT 2)
RT_literals	SELECT 42, -1, 3.14, \'hello\', NULL, true, [1, 2, 3], (1, \'a\')
RT_identifiers	SELECT a, b.c FROM t
RT_functions	SELECT plus(a, 1), count(*), quantile(0.9)(x) FROM t
RT_lambda	SELECT arrayMap(x -> (x * 2), [1, 2, 3])
RT_subquery	SELECT * FROM (SELECT 1 AS x)
RT_param	SELECT {param:UInt64}
RT_param_identifier	SELECT {x:Identifier} FROM t
RT_param_table_identifier	SELECT * FROM {tbl:Identifier}
RT_asterisk	SELECT * FROM t
RT_qual_asterisk	SELECT t.* FROM t
RT_columns_regexp	SELECT COLUMNS(\'col.*\') FROM t
RT_columns_list	SELECT COLUMNS(a, b) FROM t
RT_qual_columns_regexp	SELECT t.COLUMNS(\'x.*\') FROM t
RT_qual_columns_list	SELECT t.COLUMNS(a, b) FROM t
RT_apply	SELECT * APPLY toString FROM t
RT_except	SELECT * EXCEPT a FROM t
RT_except_strict	SELECT * EXCEPT STRICT a FROM t
RT_replace	SELECT * REPLACE (a + 1 AS a) FROM t
RT_inner_join	SELECT a FROM t1 INNER JOIN t2 ON t1.id = t2.id
RT_left_join	SELECT a FROM t1 LEFT JOIN t2 USING (id)
RT_cross_join	SELECT a FROM t1 CROSS JOIN t2
RT_global_join	SELECT a FROM t1 GLOBAL LEFT JOIN t2 ON t1.id = t2.id
RT_natural_join	SELECT a FROM t1 NATURAL INNER JOIN t2
RT_array_join	SELECT x FROM t ARRAY JOIN arr AS x
RT_left_array_join	SELECT x FROM t LEFT ARRAY JOIN arr AS x
RT_order_by	SELECT a FROM t ORDER BY a ASC NULLS FIRST, b DESC NULLS LAST
RT_order_by_fill	SELECT a FROM t ORDER BY a ASC WITH FILL FROM 1 TO 10 STEP 1
RT_window	SELECT row_number() OVER (PARTITION BY a ORDER BY b ASC ROWS BETWEEN UNBOUNDED PRECEDING AND CURRENT ROW) FROM t
RT_window_named	SELECT row_number() OVER w FROM t WINDOW w AS (PARTITION BY a ORDER BY b ASC)
RT_sample	SELECT a FROM t SAMPLE 1 / 10
RT_sample_offset	SELECT a FROM t SAMPLE 1 / 10 OFFSET 5 / 10
RT_interpolate	SELECT a, b FROM t ORDER BY a ASC WITH FILL INTERPOLATE (`b` AS b + 1)
RT_collation	SELECT a FROM t ORDER BY a ASC COLLATE \'en\'
RT_set	SET max_threads = 4
RT_explain_ast	EXPLAIN AST SELECT 1
RT_explain_syntax	EXPLAIN SYNTAX SELECT 1
RT_with	WITH x AS (SELECT 1 AS a) SELECT * FROM x
RT_rollup	SELECT a, b, count() FROM t GROUP BY a, b WITH ROLLUP
RT_cube	SELECT a, b, count() FROM t GROUP BY a, b WITH CUBE
RT_grouping_sets	SELECT a, b, count() FROM t GROUP BY GROUPING SETS ((a), (b))
RT_limit_with_ties	SELECT a FROM t ORDER BY a ASC LIMIT 5  WITH TIES
RT_limit_by	SELECT a, b FROM t LIMIT 1 BY a
RT_qualify	SELECT a, row_number() OVER (ORDER BY a ASC) AS rn FROM t QUALIFY rn <= 3
RT_settings	SELECT 1 SETTINGS max_threads = 1
RT_final	SELECT a FROM t FINAL
RT_table_func	SELECT * FROM numbers(10)
RT_create_table	CREATE TABLE db.t (`id` UInt64, `name` String DEFAULT \'x\', `ts` DateTime, INDEX idx name TYPE bloom_filter GRANULARITY 4, CONSTRAINT c CHECK id > 0, PROJECTION p (SELECT id, count() GROUP BY id)) ENGINE = MergeTree PARTITION BY toYYYYMM(ts) ORDER BY id
RT_create_ine	CREATE TABLE IF NOT EXISTS t (`a` UInt64) ENGINE = MergeTree ORDER BY a
RT_create_codec	CREATE TABLE t (`a` UInt64 COMMENT \'my col\' CODEC(LZ4)) ENGINE = MergeTree ORDER BY a
RT_create_ttl	CREATE TABLE t (`a` UInt64, `d` DateTime) ENGINE = MergeTree ORDER BY a TTL d + toIntervalDay(1)
RT_create_settings	CREATE TABLE t (`a` UInt64) ENGINE = MergeTree ORDER BY a SETTINGS index_granularity = 8192
RT_create_sample	CREATE TABLE t (`a` UInt64) ENGINE = MergeTree ORDER BY a SAMPLE BY a
RT_create_as_select	CREATE TABLE t ENGINE = MergeTree ORDER BY a AS SELECT 1 AS a
RT_create_view	CREATE VIEW v AS SELECT 1
RT_create_mv	CREATE MATERIALIZED VIEW mv ENGINE = MergeTree ORDER BY a AS SELECT 1 AS a
RT_drop_table	DROP TABLE IF EXISTS t
RT_drop_db	DROP DATABASE IF EXISTS db
RT_drop_view	DROP VIEW IF EXISTS v
RT_drop_sync	DROP TABLE IF EXISTS t SYNC
RT_insert	INSERT INTO t SELECT 1, 2
RT_insert_cols	INSERT INTO t (a, b) SELECT 1, 2
RT_alter_add	ALTER TABLE t (ADD COLUMN `c` UInt64)
RT_alter_drop	ALTER TABLE t (DROP COLUMN c)
RT_alter_modify	ALTER TABLE t (MODIFY COLUMN `c` String)
RT_alter_rename	ALTER TABLE t (RENAME COLUMN a TO b)
RT_alter_update	ALTER TABLE t (UPDATE  a = 1 WHERE b = 2)
RT_alter_delete	ALTER TABLE t (DELETE WHERE a = 1)
RT_alter_partition	ALTER TABLE t (DROP PARTITION 202301)
RT_rename	RENAME TABLE a TO b
RT_rename_db	RENAME TABLE db1.a TO db2.b
RT_exchange	EXCHANGE TABLES a AND b
RT_dictionary	CREATE DICTIONARY dict (`id` UInt64, `name` String DEFAULT \'\') PRIMARY KEY id SOURCE(CLICKHOUSE(TABLE \'t\')) LIFETIME(MIN 0 MAX 1000) LAYOUT(HASHED())
RT_dict_range	CREATE DICTIONARY dict (`id` UInt64, `start` DateTime, `end` DateTime, `name` String DEFAULT \'\') PRIMARY KEY id SOURCE(CLICKHOUSE(TABLE \'t\')) LIFETIME(MIN 0 MAX 1000) LAYOUT(RANGE_HASHED()) RANGE(MIN start MAX end)
RT_dict_settings	CREATE DICTIONARY dict (`id` UInt64, `name` String DEFAULT \'\') PRIMARY KEY id SOURCE(CLICKHOUSE(TABLE \'t\')) LIFETIME(MIN 0 MAX 1000) LAYOUT(FLAT()) SETTINGS(max_result_bytes = 1024, dictionary_use_async_executor = 1)
RT_system_flush	SYSTEM FLUSH LOGS
RT_system_stop	SYSTEM STOP MERGES t
RT_show_tables	SHOW TABLES FROM db
RT_show_tables_like	SHOW TABLES LIKE \'%test%\'
RT_show_databases	SHOW DATABASES
RT_show_columns	SHOW COLUMNS FROM t
RT_kill	KILL QUERY WHERE query_id = \'abc\' ASYNC
RT_kill_on_cluster	KILL QUERY ON CLUSTER my_cluster WHERE query_id = \'abc\' ASYNC
RT_optimize	OPTIMIZE TABLE t FINAL
RT_optimize_dedup	OPTIMIZE TABLE t FINAL DEDUPLICATE
RT_use	USE mydb
RT_check	CHECK TABLE t
RT_delete	DELETE FROM t WHERE id = 1
RT_begin	BEGIN TRANSACTION
RT_commit	COMMIT
RT_rollback	ROLLBACK
RT_backup	BACKUP TABLE t TO Disk(\'default\', \'backup1\')
RT_backup_rename_partitions	BACKUP TABLE db.t AS db2.t2 PARTITIONS  1, 2 TO Disk(\'default\', \'b1\')
RT_backup_database_except	BACKUP DATABASE db EXCEPT TABLES t1, t2 TO Disk(\'d\', \'b\')
RT_backup_all_except_databases	BACKUP ALL EXCEPT DATABASE sys TO Disk(\'d\', \'b\')
RT_backup_temporary_table	BACKUP TEMPORARY TABLE t AS s TO Disk(\'d\', \'b\')
RT_restore	RESTORE TABLE t FROM Disk(\'d\', \'b\')
RT_backup_with_base	BACKUP TABLE t TO Disk(\'d\', \'b\') SETTINGS base_backup = Disk(\'d\', \'base\')
RT_multi_join	SELECT a FROM t1 INNER JOIN t2 ON t1.id = t2.id INNER JOIN t3 ON t2.id = t3.id
RT_aliases	SELECT a AS x, b AS y FROM t AS u
RT_refresh	CREATE MATERIALIZED VIEW mv REFRESH EVERY 1 HOUR ENGINE = MergeTree ORDER BY a AS SELECT 1 AS a
RT_sql_security	CREATE VIEW v DEFINER = CURRENT_USER SQL SECURITY DEFINER AS SELECT 1
RT_create_sql_function	CREATE FUNCTION myFunc AS x -> (x + 1)
RT_create_sql_function_ine	CREATE FUNCTION IF NOT EXISTS myFunc AS x -> (x + 1)
RT_create_or_replace_sql_function	CREATE OR REPLACE FUNCTION myFunc AS x -> (x + 1)
Idempotent_select	1
Idempotent_create	1
Idempotent_dict	1
