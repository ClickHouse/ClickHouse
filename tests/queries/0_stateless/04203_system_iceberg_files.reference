file_format	String
record_count	Int64
file_size_in_bytes	Int64
partition	String
schema_id	Int32
sequence_number	Int64
sort_order_id	Nullable(Int32)
null_value_counts	Map(Int32, Int64)
column_sizes	Map(Int32, Int64)
value_counts	Map(Int32, Int64)
equality_ids	Array(Int32)
