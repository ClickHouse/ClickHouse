#!/usr/bin/env python3

# Test for JIT + CNF interaction crash.
# When JIT compilation (compile_expressions) and CNF conversion (convert_query_to_cnf)
# are both enabled, LLVM's loop vectorizer may generate code that reads past column
# data boundaries, causing a segfault if the data happens to be allocated near an
# unmapped page boundary. This is most reliably reproduced in UBSan builds.
#
# The test generates random DNF boolean expressions, evaluates them with JIT + CNF
# enabled, and compares results against a baseline without these optimizations.
# A crash (segfault) or result mismatch indicates a bug.

# Tags: long, no-fasttest

import os
import sys
from random import choices, randint, seed

CURDIR = os.path.dirname(os.path.realpath(__file__))
sys.path.insert(0, os.path.join(CURDIR, "helpers"))

from pure_http_client import ClickHouseClient

client = ClickHouseClient()

N = 10
MAX_CLAUSES = 10
MAX_ATOMS = 5
NUM_TRIALS = 2000

seed(42)

create_query = (
    "CREATE TABLE t_cnf_jit("
    + ", ".join([f"c{i} UInt8" for i in range(N)])
    + ") ENGINE = Memory"
)

client.query("DROP TABLE IF EXISTS t_cnf_jit")
client.query(create_query)

insert_query = "INSERT INTO t_cnf_jit VALUES "
for i in range(2**N):
    values = []
    cur = i
    for _ in range(N):
        values.append(cur % 2)
        cur //= 2
    insert_query += "(" + ", ".join(map(str, values)) + ")"

client.query(insert_query)


def generate_dnf():
    clauses = []
    num_clauses = randint(1, MAX_CLAUSES)
    for _ in range(num_clauses):
        num_atoms = randint(1, MAX_ATOMS)
        atom_ids = choices(range(N), k=num_atoms)
        negates = choices([0, 1], k=num_atoms)
        atoms = [
            f"(NOT c{i})" if neg else f"c{i}" for (i, neg) in zip(atom_ids, negates)
        ]
        clauses.append("(" + " AND ".join(atoms) + ")")
    return " OR ".join(clauses)


base_query = "SELECT count() FROM t_cnf_jit WHERE {condition} SETTINGS compile_expressions = 0, convert_query_to_cnf = 0"
jit_cnf_query = "SELECT count() FROM t_cnf_jit WHERE {condition} SETTINGS compile_expressions = 1, min_count_to_compile_expression = 0, convert_query_to_cnf = 1"

for trial in range(NUM_TRIALS):
    condition = generate_dnf()

    res_base = client.query(base_query.format(condition=condition)).strip()
    res_jit_cnf = client.query(jit_cnf_query.format(condition=condition)).strip()

    if res_base != res_jit_cnf:
        print(
            f"MISMATCH at trial {trial}.\n"
            f"Condition: {condition}\n"
            f"Baseline (no JIT, no CNF): {res_base}\n"
            f"JIT + CNF: {res_jit_cnf}"
        )
        client.query("DROP TABLE t_cnf_jit")
        sys.exit(1)

client.query("DROP TABLE t_cnf_jit")
print("OK")
