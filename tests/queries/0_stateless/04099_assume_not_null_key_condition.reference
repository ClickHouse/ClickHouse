      Filter ((WHERE + Change column names to column identifiers))
        ReadFromMergeTree (default.test)
        Indexes:
          Partition Min-Max
            Keys:
              d
            Condition: (d in (-Inf, 16435])
            Parts: 2/4
            Granules: 2/4
          Partition
            Keys:
              toRelativeDayNum(assumeNotNull(d))
            Condition: (toRelativeDayNum(assumeNotNull(d)) in (-Inf, 16436])
            Parts: 2/2
            Granules: 2/2
          Ranges: 2
SELECT arraySort(groupArray(if(isNull(d), 'NULL', toString(d)))) FROM test WHERE d = '1970-01-01';
['1970-01-01']
EXPLAIN indexes = 1 SELECT arraySort(groupArray(if(isNull(d), 'NULL', toString(d)))) FROM test WHERE d = '1970-01-01';
