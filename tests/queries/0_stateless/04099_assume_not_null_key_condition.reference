SELECT arraySort(groupArray(if(isNull(d), 'NULL', toString(d)))) FROM test WHERE d = '2015-01-01';
['2015-01-01']
EXPLAIN indexes = 1 SELECT arraySort(groupArray(if(isNull(d), 'NULL', toString(d)))) FROM test WHERE d = '2015-01-01';
