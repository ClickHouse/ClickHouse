--- merge / fetch / move / sends / ttl / cleanup start/stop ---
SYSTEM STOP MERGES db.t
SYSTEM START MERGES db.t
SYSTEM STOP TTL MERGES
SYSTEM START TTL MERGES
SYSTEM STOP FETCHES db.t
SYSTEM START FETCHES db.t
SYSTEM STOP MOVES db.t
SYSTEM START MOVES db.t
SYSTEM STOP REPLICATED SENDS db.t
SYSTEM START REPLICATED SENDS db.t
SYSTEM STOP DISTRIBUTED SENDS db.t
SYSTEM START DISTRIBUTED SENDS db.t
SYSTEM STOP REPLICATION QUEUES db.t
SYSTEM START REPLICATION QUEUES db.t
SYSTEM STOP REPLICATED DDL QUERIES
SYSTEM START REPLICATED DDL QUERIES
SYSTEM STOP CLEANUP db.t
SYSTEM START CLEANUP db.t
SYSTEM STOP PULLING REPLICATION LOG db.t
SYSTEM START PULLING REPLICATION LOG db.t
--- reload / restart / replica management ---
SYSTEM RELOAD DICTIONARY d
SYSTEM RELOAD DICTIONARIES
SYSTEM RELOAD FUNCTION f
SYSTEM RELOAD FUNCTIONS
SYSTEM RELOAD EMBEDDED DICTIONARIES
SYSTEM RELOAD CONFIG
SYSTEM RELOAD USERS
SYSTEM RELOAD ASYNCHRONOUS METRICS
SYSTEM RESTART REPLICA db.t
SYSTEM RESTART REPLICAS
SYSTEM RESTORE REPLICA db.t
SYSTEM DROP REPLICA \'r1\' FROM TABLE db.t
SYSTEM DROP REPLICA \'r1\' FROM DATABASE db
SYSTEM DROP REPLICA \'r1\' FROM ZKPATH \'/clickhouse/zkpath\'
SYSTEM DROP DATABASE REPLICA \'r1\' FROM DATABASE db
SYSTEM DROP DATABASE REPLICA \'r1\' FROM ZKPATH \'/clickhouse/zkpath\'
SYSTEM SYNC REPLICA db.t STRICT
SYSTEM SYNC REPLICA db.t LIGHTWEIGHT
SYSTEM SYNC DATABASE REPLICA db
SYSTEM SYNC TRANSACTION LOG
SYSTEM SYNC FILE CACHE
SYSTEM WAIT LOADING PARTS db.t
--- thread fuzzer / failpoints / jemalloc ---
SYSTEM START THREAD FUZZER
SYSTEM STOP THREAD FUZZER
SYSTEM ENABLE FAILPOINT fp
SYSTEM DISABLE FAILPOINT fp
SYSTEM JEMALLOC PURGE
SYSTEM JEMALLOC ENABLE PROFILE
SYSTEM JEMALLOC DISABLE PROFILE
SYSTEM JEMALLOC FLUSH PROFILE
--- views / primary key ---
SYSTEM REFRESH VIEW db.v
SYSTEM STOP VIEW db.v
SYSTEM START VIEW db.v
SYSTEM CANCEL VIEW db.v
SYSTEM STOP VIEWS
SYSTEM START VIEWS
SYSTEM LOAD PRIMARY KEY db.t
SYSTEM UNLOAD PRIMARY KEY db.t
--- flush variants ---
SYSTEM FLUSH LOGS query_log
SYSTEM FLUSH DISTRIBUTED db.t
SYSTEM FLUSH ASYNC INSERT QUEUE
--- listening / admin ---
SYSTEM STOP LISTEN QUERIES ALL
SYSTEM START LISTEN QUERIES ALL
SYSTEM STOP LISTEN TCP
SYSTEM START LISTEN TCP
--- unfreeze / restart disk ---
SYSTEM UNFREEZE WITH NAME \'snap1\'
SYSTEM RESTART DISK my_disk
--- ON CLUSTER clause ---
SYSTEM FLUSH LOGS ON CLUSTER my_cluster
SYSTEM RELOAD DICTIONARY ON CLUSTER my_cluster d
