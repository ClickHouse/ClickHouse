CREATE MASKING POLICY p ON db.t UPDATE email = '***' TO ALL
CREATE MASKING POLICY p ON t UPDATE email = '***' TO ALL
CREATE MASKING POLICY p ON db.t IN some_storage UPDATE email = '***' TO ALL
CREATE MASKING POLICY IF NOT EXISTS p ON db.t UPDATE email = '***' WHERE id > 0 TO ALL PRIORITY 5
CREATE MASKING POLICY OR REPLACE p ON db.t UPDATE email = '***' TO ALL
ALTER MASKING POLICY IF EXISTS p ON db.t UPDATE email = '***'
ALTER MASKING POLICY p ON db.t RENAME TO q
