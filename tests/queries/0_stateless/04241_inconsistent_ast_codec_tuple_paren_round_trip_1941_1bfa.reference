CREATE TABLE t (`c0` Int CODEC(not(not(tuple(materialize(1), materialize(2)))), ZSTD)) ENGINE = Memory
CREATE TABLE t (`c0` Int CODEC(not(tuple(1, 2)), ZSTD)) ENGINE = Memory
CREATE TABLE t (`c0` Int CODEC(not(tuple(1, 2, 3)), ZSTD)) ENGINE = Memory
CREATE TABLE t (`c0` Int CODEC(not(tuple(materialize(1), materialize(2), materialize(3))), ZSTD)) ENGINE = Memory
CREATE TABLE t (`c0` Int CODEC(not(tuple(1)), ZSTD)) ENGINE = Memory
ALTER TABLE t (MODIFY STATISTICS  c0 TYPE  concatAssumeInjective((1, 2)))
ALTER TABLE t (MODIFY STATISTICS  c0 TYPE  concatAssumeInjective(tuple(1, 2)))
CREATE TABLE default.t_codec_real\n(\n    `c0` Int32 CODEC(Delta(8), LZ4)\n)\nENGINE = Memory
SELECT tuple(1, 2), (1, 2), (tuple(1, 2))
SELECT 1 WHERE (1, 2) NOT IN (3, 4)
RESTORE TABLE src AS dst FROM Memory(not(not(tuple(materialize(1), materialize(2)))))
BACKUP TABLE src TO Memory(not(tuple(1, 2, 3)))
BACKUP TABLE src TO Memory(not(tuple(materialize(1), materialize(2))))
