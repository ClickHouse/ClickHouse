SELECT count() AS `count()`
FROM default.s_users AS __table1
SEMI LEFT JOIN
(
    SELECT __table3.uid AS uid
    FROM default.s_users AS __table3
    SAMPLE 1 / 2
) AS __table2 ON __table1.uid = __table2.uid
SEMI LEFT JOIN
(
    SELECT __table5.uid AS uid
    FROM default.s_users AS __table5
    SAMPLE 1 / 2 OFFSET 1 / 2
) AS __table4 ON __table1.uid = __table4.uid
SETTINGS optimize_remove_redundant_semi_join = 0
