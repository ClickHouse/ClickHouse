-- query opt=0 --
SELECT __table1.uid AS `u1.uid`
FROM default.users AS __table1
SEMI LEFT JOIN default.users AS __table2 ON __table1.uid = __table2.uid
SEMI LEFT JOIN
(
    SELECT __table4.uid AS uid
    FROM default.users AS __table4
    WHERE __table4.age = 33
) AS __table3 ON __table1.uid = __table3.uid
ORDER BY __table1.uid ASC
