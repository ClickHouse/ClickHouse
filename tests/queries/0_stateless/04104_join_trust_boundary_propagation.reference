-- trusted: stats materialized, inner join cardinality propagates
Join: sub[1000] ⋈ o[100]
ResultRows: 100
Join: a[1000] ⋈ b[1000]
ResultRows: 1000
-- untrusted: no stats, inner join cardinality is hidden from upstream
Join: o[100] ⋈ sub
ResultRows: unknown
Join: a[1000] ⋈ b[1000]
ResultRows: unknown
