SELECT avg(number + 2) FROM numbers(10)
value: 	6.5
EXPLAIN syntax:
SELECT plus(avg(number), 2)
FROM numbers(10)

SELECT avg(number - 2) FROM numbers(10)
value: 	2.5
EXPLAIN syntax:
SELECT minus(avg(number), 2)
FROM numbers(10)

SELECT avg(number * 2) FROM numbers(10)
value: 	9
EXPLAIN syntax:
SELECT multiply(avg(number), 2)
FROM numbers(10)

SELECT avg(number / 2) FROM numbers(10)
value: 	2.25
EXPLAIN syntax:
SELECT divide(avg(number), 2)
FROM numbers(10)
