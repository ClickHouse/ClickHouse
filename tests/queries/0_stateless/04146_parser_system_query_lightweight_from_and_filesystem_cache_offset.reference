--- SYSTEM SYNC REPLICA ... LIGHTWEIGHT FROM ... (multi-replica) ---
SYSTEM SYNC REPLICA db.t LIGHTWEIGHT FROM \'r1\'
SYSTEM SYNC REPLICA db.t LIGHTWEIGHT FROM \'r1\', \'r2\'
SYSTEM SYNC REPLICA db.t LIGHTWEIGHT FROM \'r1\', \'r2\', \'r3\'
--- SYSTEM DROP FILESYSTEM CACHE with KEY + OFFSET ---
SYSTEM CLEAR FILESYSTEM CACHE \'my_cache\' KEY xyz OFFSET 0
SYSTEM CLEAR FILESYSTEM CACHE \'my_cache\' KEY xyz OFFSET 4096
--- SYSTEM DROP REPLICA ... FROM SHARD ---
SYSTEM DROP REPLICA \'r1\' FROM SHARD \'s1\'
SYSTEM DROP REPLICA \'r1\' FROM SHARD \'s1\' FROM TABLE db.t
SYSTEM DROP REPLICA \'r1\' FROM SHARD \'s1\' FROM ZKPATH \'/clickhouse/zkpath\'
--- SYSTEM NOTIFY FAILPOINT ---
SYSTEM NOTIFY FAILPOINT fp
