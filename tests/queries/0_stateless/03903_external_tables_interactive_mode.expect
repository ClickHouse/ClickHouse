#!/usr/bin/expect -f
# Tags: no-fasttest

set basedir [file dirname $argv0]
set basename [file tail $argv0]
if {[info exists env(CLICKHOUSE_TMP)]} {
    set CLICKHOUSE_TMP $env(CLICKHOUSE_TMP)
} else {
    set CLICKHOUSE_TMP "."
}
exp_internal -f $CLICKHOUSE_TMP/$basename.debuglog 0

log_user 0
set timeout 60
match_max 100000

expect_after {
    -i $any_spawn_id eof { exp_continue }
    -i $any_spawn_id timeout { exit 1 }
}

if {[info exists env(CLICKHOUSE_DATABASE)]} {
    set CLICKHOUSE_DATABASE $env(CLICKHOUSE_DATABASE)
} else {
    set CLICKHOUSE_DATABASE "default"
}

set tmp_file "$CLICKHOUSE_TMP/${CLICKHOUSE_DATABASE}_data_1.csv"
set fp [open $tmp_file w]
puts $fp "1,Alice"
puts $fp "2,Bob"
puts $fp "3,Charlie"
close $fp

spawn bash -c "source $basedir/../shell_config.sh ; \$CLICKHOUSE_CLIENT_BINARY \$CLICKHOUSE_CLIENT_EXPECT_OPT --external --file='$tmp_file' --name=users --structure='id UInt32, name String' --format=CSV"
expect ":) "

send -- "SET max_threads = 4; SELECT * FROM users ORDER BY id;\r"
expect "Alice"
expect "Bob"
expect "Charlie"
expect ":) "

send -- "SET max_block_size = 1000;\r"
expect ":) "

send -- "SELECT count() FROM users;\r"
expect "3"
expect ":) "

# ctrl+D
send -- "\4"
expect eof

file delete $tmp_file
