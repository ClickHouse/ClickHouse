-- Multiple Key Columns
SELECT number, number % 2 AS g1, number % 3 AS g2 FROM numbers(12) ORDER BY g1, g2, number LIMIT -1 BY g1, g2;
6	0	0
10	0	1
8	0	2
9	1	0
7	1	1
11	1	2
SELECT number, number % 2 AS g1, number % 3 AS g2 FROM numbers(12) ORDER BY number LIMIT -1 BY g1, g2;
6	0	0
7	1	1
8	0	2
9	1	0
10	0	1
11	1	2
-- String Keys
SELECT number, toString(number % 2) AS g FROM numbers(10) ORDER BY g, number LIMIT -1 BY g;
8	0
9	1
SELECT number, toString(number % 2) AS g FROM numbers(10) ORDER BY number LIMIT -1 BY g;
8	0
9	1
-- Misc
SELECT DISTINCT number % 8 AS x FROM numbers(120) ORDER BY x LIMIT -3 OFFSET -2 BY x;
SELECT DISTINCT number % 8 AS x FROM numbers(120) ORDER BY toString(x) LIMIT -3 OFFSET -2 BY x;
SELECT DISTINCT number % 80 AS x FROM numbers(120) ORDER BY x LIMIT -3 OFFSET 50 BY x;
SELECT DISTINCT number % 80 AS x FROM numbers(120) ORDER BY toString(x) LIMIT -3 OFFSET 50 BY x;
SELECT number, number % 3 AS g FROM numbers(1000000) ORDER BY g, number LIMIT -1 BY g;
