<clickhouse>
    <logger>
        <level>trace</level>
        <log>clickhouse-server.log</log>
        <errorlog>clickhouse-server.err.log</errorlog>
    </logger>

    <listen_host>127.1</listen_host>
    <http_port>3742</http_port>
    <tcp_port>9742</tcp_port>

    <shutdown_wait_unfinished>0</shutdown_wait_unfinished>
    <path>.</path>
    <mark_cache_size>0</mark_cache_size>

    <access_control_path>03742_functions_deny_list/access</access_control_path>

    <table_functions_deny_list>
        <name>remote</name>
        <name>remoteSecure</name>
        <name>values</name>
        <name>FORMAT</name>
    </table_functions_deny_list>

    <udfs_deny_list>
        <name>test_function_bash</name>
        <type>executable</type>
    </udfs_deny_list>

    <user_defined_executable_functions_config>03742_functions_deny_list/test_function_config.xml</user_defined_executable_functions_config>

    <profiles>
        <default/>
    </profiles>

    <users>
        <default>
            <password/>

            <networks>
                <ip>::/0</ip>
            </networks>
        </default>
    </users>

    <quotas>
        <default/>
    </quotas>
</clickhouse>
