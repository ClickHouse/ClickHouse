#!/usr/bin/expect -f

# Test that tab characters pasted into the interactive client are rendered
# as spaces (not ^I) while preserving the actual tab in the query.
# Regression test for https://github.com/ClickHouse/ClickHouse/issues/100405

set basedir [file dirname $argv0]
set basename [file tail $argv0]
if {[info exists env(CLICKHOUSE_TMP)]} {
    set CLICKHOUSE_TMP $env(CLICKHOUSE_TMP)
} else {
    set CLICKHOUSE_TMP "."
}
exp_internal -f $CLICKHOUSE_TMP/$basename.debuglog 0
set history_file $CLICKHOUSE_TMP/$basename.history

log_user 0
set timeout 60
match_max 100000

expect_after {
    # Do not ignore eof from expect
    -i $any_spawn_id eof { exp_continue }
    # A default timeout action is to do nothing, change it to fail
    -i $any_spawn_id timeout { exit 1 }
}

spawn bash -c "source $basedir/../shell_config.sh ; \$CLICKHOUSE_CLIENT_BINARY \$CLICKHOUSE_CLIENT_EXPECT_OPT --history_file=$history_file"
expect ":) "

# Use bracketed paste mode to simulate pasting text with a tab character.
# When pasting, terminals wrap the content in ESC[200~ ... ESC[201~.
# This is the only way tabs reach the buffer as literal characters;
# outside of paste mode, tab triggers completion instead.
send -- "\033\[200~SELECT\t1\033\[201~"
send -- "\r"
# The echoed command should show spaces, not ^I
expect {
    "^I" { puts "FAIL: tab rendered as ^I"; exit 1 }
    "SELECT    1" {}
    timeout { exit 1 }
}
expect "1"
expect ":) "

# Verify that the tab character is preserved in the actual query,
# i.e. string functions see a real tab, not spaces.
send -- "\033\[200~SELECT position('a\tb', '\t')\033\[201~"
send -- "\r"
expect "2"
expect ":) "

send -- "exit\r"
expect eof
