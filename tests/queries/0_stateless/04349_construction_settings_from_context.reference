-- a session SET limit shapes a plain SELECT (2 rows returned)
0
1
-- but a session SET limit does not propagate into INSERT ... SELECT (all 10 rows)
10
-- a session SET filter does not propagate into INSERT ... SELECT (all 10 rows)
10
