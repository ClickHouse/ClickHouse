SELECT
    date,
    id,
    name,
    value
FROM
(
    SELECT *
    FROM default.test
    HAVING equals(id, 1)
) AS test_view
WHERE equals(id, 1)
SELECT
    date,
    id,
    name,
    value
FROM
(
    SELECT *
    FROM default.test
    HAVING equals(id, 2)
) AS test_view
WHERE equals(id, 2)
SELECT id
FROM
(
    SELECT *
    FROM default.test
    HAVING equals(id, 1)
) AS test_view
WHERE equals(id, 1)
SELECT id
FROM
(
    SELECT *
    FROM default.test
    HAVING equals(id, 1)
) AS s
WHERE equals(id, 1)
