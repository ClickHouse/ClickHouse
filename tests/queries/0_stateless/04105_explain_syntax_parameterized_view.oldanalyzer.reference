SELECT number
FROM
(
    SELECT number
    FROM numbers(_CAST(15, \'UInt64\'))
    WHERE greater(number, 10)
) AS `04105_pv`
SELECT number
FROM
(
    SELECT number
    FROM numbers(_CAST(20, \'UInt64\'))
    WHERE greater(number, _CAST(5, \'UInt64\'))
) AS `04105_pv_multi`
SELECT number
FROM
(
    SELECT number
    FROM
    (
        SELECT number
        FROM numbers(_CAST(5, \'UInt64\'))
        WHERE greater(number, 0)
    ) AS `04105_pv_nested_inner`
    WHERE greater(number, 0)
) AS `04105_pv_nested_outer`
SELECT x
FROM
(
    SELECT 1 AS x
) AS `04105_plain_view`
SELECT number
FROM
(
    SELECT number
    FROM
    (
        SELECT number
        FROM numbers(_CAST(12, \'UInt64\'))
        WHERE greater(number, 10)
    ) AS `04105_pv`
)
SELECT number
FROM `04105_join_target`
ALL INNER JOIN
(
    SELECT number
    FROM numbers(_CAST(10, \'UInt64\'))
    WHERE greater(number, 10)
) AS `04105_pv` USING (number)
SELECT number
FROM
(
    SELECT number
    FROM numbers(_CAST(10, \'UInt64\'))
    WHERE greater(number, 10)
) AS t
SELECT *
FROM numbers(3)
SETTINGS allow_experimental_analyzer = 1
SELECT x
FROM
(
    SELECT x
    FROM default.`04105_modifiers_t`
    WHERE greater(x, _CAST(1, \'UInt64\'))
) AS `04105_modifiers_pv`
FINAL
SELECT count()
FROM
(
    SELECT x
    FROM default.`04105_modifiers_t`
    WHERE greater(x, _CAST(1, \'UInt64\'))
) AS `04105_modifiers_pv`
SAMPLE 5 / 10
SELECT x
FROM
(
    SELECT x
    FROM default.`04105_security_t`
    WHERE greater(x, _CAST(1, \'UInt64\'))
) AS `04105_pv_security_none`
SELECT x
FROM
(
    SELECT x
    FROM default.`04105_security_t`
    WHERE greater(x, _CAST(1, \'UInt64\'))
) AS `04105_pv_security_definer`
