SELECT number
FROM
(
    SELECT number
    FROM numbers(_CAST(15, \'UInt64\'))
    WHERE number > 10
) AS `04105_pv`
SELECT number
FROM
(
    SELECT number
    FROM numbers(_CAST(20, \'UInt64\'))
    WHERE number > _CAST(5, \'UInt64\')
) AS `04105_pv_multi`
SELECT number
FROM
(
    SELECT number
    FROM
    (
        SELECT number
        FROM numbers(_CAST(5, \'UInt64\'))
        WHERE number > 0
    ) AS `04105_pv_nested_inner`
    WHERE number > 0
) AS `04105_pv_nested_outer`
SELECT x
FROM
(
    SELECT 1 AS x
) AS `04105_plain_view`
SELECT number
FROM
(
    SELECT number
    FROM
    (
        SELECT number
        FROM numbers(_CAST(12, \'UInt64\'))
        WHERE number > 10
    ) AS `04105_pv`
)
SELECT number
FROM `04105_join_target`
ALL INNER JOIN
(
    SELECT number
    FROM numbers(_CAST(10, \'UInt64\'))
    WHERE number > 10
) AS `04105_pv` USING (number)
SELECT number
FROM
(
    SELECT number
    FROM numbers(_CAST(10, \'UInt64\'))
    WHERE number > 10
) AS t
