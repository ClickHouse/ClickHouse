SHOW COLUMNS FROM t FORMAT JSON
OPTIMIZE TABLE t FINAL FORMAT `Null`
RENAME TABLE a TO b FORMAT `Null`
EXPLAIN SELECT 1 FORMAT JSON
DROP TEMPORARY TABLE t
SELECT * FROM a INNER JOIN b USING (x)
SELECT * FROM a INNER JOIN b ON a.x = b.x
SELECT COLUMNS(\'^c\') APPLY sum FROM t
SELECT COLUMNS(\'^c\') APPLY x -> (x + 1) FROM t
SELECT count() OVER (ORDER BY x ASC ROWS BETWEEN 1 PRECEDING AND CURRENT ROW) FROM t
SELECT * FROM t SAMPLE 1 / 3
ALTER TABLE t (MOVE PARTITION 1 TO DISK \'d\')
ALTER TABLE t (MOVE PARTITION 1 TO TABLE db.t2)
select Date from t
