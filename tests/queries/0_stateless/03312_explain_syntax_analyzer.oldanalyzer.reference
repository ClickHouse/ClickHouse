-- { echoOn }
EXPLAIN SYNTAX run_query_tree_passes = 1, oneline = 1
select  *
from
system.numbers AS a,
system.numbers AS b,
system.numbers AS c
WHERE a.number == 1 OR a.number == 2 OR a.number == 3 OR a.number = 4 OR a.number = 5
;
