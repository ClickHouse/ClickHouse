SELECT
    `--a.number` AS `a.number`,
    `--b.number` AS `b.number`,
    `--c.number` AS `c.number`
FROM
(
    SELECT
        number AS `--a.number`,
        b.number AS `--b.number`
    FROM system.numbers AS a
    CROSS JOIN system.numbers AS b
    WHERE (number AS `--a.number`) IN (1, 2, 3, 4, 5)
) AS `--.s`
CROSS JOIN
(
    SELECT number AS `--c.number`
    FROM system.numbers AS c
) AS `--.t`
WHERE `--a.number` IN (1, 2, 3, 4, 5)
SELECT `--a.number` AS `a.number`, `--b.number` AS `b.number`, `--c.number` AS `c.number` FROM (SELECT number AS `--a.number`, b.number AS `--b.number` FROM system.numbers AS a CROSS JOIN system.numbers AS b WHERE (number AS `--a.number`) IN (1, 2, 3, 4, 5)) AS `--.s` CROSS JOIN (SELECT number AS `--c.number` FROM system.numbers AS c) AS `--.t` WHERE `--a.number` IN (1, 2, 3, 4, 5)
