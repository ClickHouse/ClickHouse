-- The `limit`/`offset` settings cap must be applied once over the final set-operation result, not once
-- per branch. INTERSECT/EXCEPT also plan through UnionNode (analyzer), so range branches must move their
-- settings cap onto the set-operation node just like UNION ALL. On the legacy interpreter
-- (enable_analyzer = 0) the cap is applied once after IntersectOrExceptStep as well, so both paths agree.
-- The results below are deterministic because INTERSECT/EXCEPT emit rows in the (sorted) order of their
-- first input.

-- { echo }

-- INTERSECT of 0..9 with itself = 0..9; settings limit caps to 3.
(SELECT number AS n FROM numbers(10) LIMIT AFTER number >= 0) INTERSECT (SELECT number AS n FROM numbers(10) LIMIT AFTER number >= 0) SETTINGS limit = 3;
0
1
2
(SELECT number AS n FROM numbers(10) LIMIT AFTER number >= 0) INTERSECT (SELECT number AS n FROM numbers(10) LIMIT AFTER number >= 0) SETTINGS limit = 3, enable_analyzer = 0;
0
1
2
-- EXCEPT: 0..9 except 0..4 = 5..9; settings limit caps to 2.
(SELECT number AS n FROM numbers(10) LIMIT AFTER number >= 0) EXCEPT (SELECT number AS n FROM numbers(5) LIMIT AFTER number >= 0) SETTINGS limit = 2;
5
6
(SELECT number AS n FROM numbers(10) LIMIT AFTER number >= 0) EXCEPT (SELECT number AS n FROM numbers(5) LIMIT AFTER number >= 0) SETTINGS limit = 2, enable_analyzer = 0;
5
6
-- UNTIL branch variant: left branch 0..7 (until 8), intersect with 0..9 = 0..7, cap to 2.
(SELECT number AS n FROM numbers(10) LIMIT UNTIL number >= 8) INTERSECT (SELECT number AS n FROM numbers(10) LIMIT AFTER number >= 0) SETTINGS limit = 2;
0
1
(SELECT number AS n FROM numbers(10) LIMIT UNTIL number >= 8) INTERSECT (SELECT number AS n FROM numbers(10) LIMIT AFTER number >= 0) SETTINGS limit = 2, enable_analyzer = 0;
0
1
-- Branch-local settings must remain scoped to their own subqueries.
SELECT * FROM (SELECT * FROM (SELECT number AS n FROM numbers(5) LIMIT AFTER number >= 0 SETTINGS limit = 2, offset = 1) UNION ALL SELECT * FROM (SELECT number AS n FROM numbers(5) LIMIT AFTER number >= 0 SETTINGS limit = 2, offset = 2)) ORDER BY n;
1
2
2
3
-- Mixed range/non-range branches must apply the settings cap once over the final set-operation result.
-- UNION ALL does not promise branch order, so the result is ordered before applying the cap to keep the
-- assertion deterministic; the cap (offset = 4, limit = 3) is still applied once over the whole result.
SELECT n FROM ((SELECT number + 10 AS n FROM numbers(5)) UNION ALL (SELECT number AS n FROM numbers(5) LIMIT AFTER number >= 0)) ORDER BY n SETTINGS limit = 3, offset = 4;
4
10
11
SELECT n FROM ((SELECT number + 10 AS n FROM numbers(5)) UNION ALL (SELECT number AS n FROM numbers(5) LIMIT AFTER number >= 0)) ORDER BY n SETTINGS limit = 3, offset = 4, enable_analyzer = 0;
4
10
11
-- Query-tree-to-AST conversion must preserve the settings cap carried by UnionNode. This is an
-- analyzer-only concern, so enable_analyzer is pinned: the legacy parser formats the query differently
-- (no parentheses, no trailing SETTINGS), which would otherwise make the output depend on the CI run.
EXPLAIN SYNTAX (SELECT number AS n FROM numbers(5) LIMIT AFTER number >= 0) UNION ALL (SELECT number AS n FROM numbers(5) LIMIT AFTER number >= 0) SETTINGS limit = 2, offset = 1, enable_analyzer = 1;
(
    SELECT number AS n
    FROM numbers(5)
    LIMIT
     AFTER greaterOrEquals(number, 0)
)
UNION ALL
(
    SELECT number AS n
    FROM numbers(5)
    LIMIT
     AFTER greaterOrEquals(number, 0)
)
SETTINGS limit = 2, offset = 1
