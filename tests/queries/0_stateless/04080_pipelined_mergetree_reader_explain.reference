-- Standard reader: InOrder
digraph
{
  rankdir="LR";
  { node [shape = rect]
    n0[label="MergeTreeSelect(pool: ReadPoolInOrder, algorithm: InOrder)_1"];
    n1[label="ExpressionTransform_2"];
    n2[label="AggregatingTransform_3"];
