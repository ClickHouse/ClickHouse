-- Standard reader pipeline
digraph
{
  rankdir="LR";
  { node [shape = rect]
    n0[label="MergeTreeSelect(pool: ReadPool, algorithm: Thread)_1"];
    n1[label="MergeTreeSelect(pool: ReadPool, algorithm: Thread)_2"];
    n2[label="ExpressionTransform_3"];
    n3[label="ExpressionTransform_4"];
    n4[label="AggregatingTransform_5"];
    n5[label="AggregatingTransform_6"];
    n6[label="Resize_7"];
    n7[label="ExpressionTransform_8"];
    n8[label="ExpressionTransform_9"];
  }
  n0 -> n2;
  n1 -> n3;
  n2 -> n4;
  n3 -> n5;
  n4 -> n6;
  n5 -> n6;
  n6 -> n7;
  n6 -> n8;
}
