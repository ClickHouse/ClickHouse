<test>
    <settings>
        <optimize_read_in_order>1</optimize_read_in_order>
        <max_threads>8</max_threads>
    </settings>

    <!-- Multi-part table: PARTITION BY keeps several parts after merges, so that
         `ReadFromMergeTree::spreadMarkRangesAmongStreamsWithOrder` exercises the
         per-part `PrefetchingConcatProcessor` path, which is enabled only when
         `parts_with_ranges.size() > 1`. With four large parts and `max_threads = 8`,
         each part is split into multiple streams that `PrefetchingConcat` reads in
         parallel while preserving the per-part order. -->
    <create_query>
        CREATE TABLE read_in_order_multi_part (key String, payload UInt64)
        ENGINE = MergeTree PARTITION BY intDiv(payload, 12500000) ORDER BY key
        AS SELECT concat('k/', toString(number % 100000), '/v'), number FROM numbers_mt(50000000)
    </create_query>

    <!-- One part per partition (four parts total); the per-part `PrefetchingConcat`
         path stays active because there are multiple parts. -->
    <fill_query>OPTIMIZE TABLE read_in_order_multi_part FINAL</fill_query>

    <!-- Poor PK selectivity: LIKE '%...' cannot use the index, all granules are read.
         Each part is split into multiple parallel streams merged by `PrefetchingConcat`. -->
    <query>SELECT * FROM read_in_order_multi_part WHERE key LIKE '%/v' ORDER BY key FORMAT Null</query>

    <!-- Reverse direction: exercises the reversed-pipe branch of `PrefetchingConcat`. -->
    <query>SELECT * FROM read_in_order_multi_part WHERE key LIKE '%/v' ORDER BY key DESC FORMAT Null</query>

    <!-- Good PK selectivity: LIKE 'prefix%' uses the index, few granules are read. -->
    <query>SELECT * FROM read_in_order_multi_part WHERE key LIKE 'k/1%' ORDER BY key FORMAT Null</query>

    <!-- ORDER BY without WHERE: all granules, tests pure read + concat throughput. -->
    <query>SELECT * FROM read_in_order_multi_part ORDER BY key FORMAT Null</query>

    <!-- Aggregation in order on the same multi-part table: `PrefetchingConcat` is
         disabled here (downstream wants multiple streams), but per-part splitting
         still applies. -->
    <query>SELECT key, sum(payload) FROM read_in_order_multi_part GROUP BY key ORDER BY key FORMAT Null SETTINGS optimize_aggregation_in_order = 1</query>

    <drop_query>DROP TABLE IF EXISTS read_in_order_multi_part</drop_query>
</test>
