<clickhouse>
    <profiles>
        <default>
            <!-- The session-token / IMDS Delta tests read S3 via server-managed credentials (environment or
                 instance-metadata), which are blocked for user queries by default. Allow it here. -->
            <s3_allow_server_credentials_in_user_queries>1</s3_allow_server_credentials_in_user_queries>
        </default>
    </profiles>
</clickhouse>
