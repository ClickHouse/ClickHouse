<clickhouse>
    <filesystem_caches_path>/var/lib/clickhouse/filesystem_caches/</filesystem_caches_path>
    <custom_cached_disks_base_directory>/var/lib/clickhouse/custom_cached/</custom_cached_disks_base_directory>
    <custom_local_disks_base_directory>/var/lib/clickhouse/custom_local/</custom_local_disks_base_directory>

    <storage_configuration>
        <disks>
            <obj_local>
                <type>object_storage</type>
                <object_storage_type>local</object_storage_type>
                <path>obj_local/</path>
            </obj_local>
        </disks>
    </storage_configuration>
</clickhouse>
