<clickhouse>
    <http_handlers>
        <rule>
            <methods>GET</methods>
            <url_regexp>/test_regexp/[0-9]+</url_regexp>
            <handler>
                <type>static</type>
                <status>200</status>
                <content_type>text/plain; charset=UTF-8</content_type>
                <response_content>regex handler matched</response_content>
            </handler>
        </rule>
    </http_handlers>
</clickhouse>
