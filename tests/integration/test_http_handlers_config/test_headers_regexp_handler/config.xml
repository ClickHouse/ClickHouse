<clickhouse>
    <http_handlers>
        <rule>
            <methods>GET</methods>
            <url>/test_headers_regex</url>
            <headers_regexp><XXX>[0-9]+</XXX></headers_regexp>
            <handler>
                <type>static</type>
                <status>200</status>
                <content_type>text/plain; charset=UTF-8</content_type>
                <response_content>headers regex handler matched</response_content>
            </handler>
        </rule>
    </http_handlers>
</clickhouse>
