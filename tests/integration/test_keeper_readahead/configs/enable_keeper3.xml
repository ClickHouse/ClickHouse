<clickhouse>
    <keeper_server>
        <tcp_port>9181</tcp_port>
        <server_id>3</server_id>
        <log_storage_path>/var/lib/clickhouse/coordination/log</log_storage_path>
        <snapshot_storage_path>/var/lib/clickhouse/coordination/snapshots</snapshot_storage_path>
        <create_snapshot_on_exit>false</create_snapshot_on_exit>

        <coordination_settings>
            <operation_timeout_ms>5000</operation_timeout_ms>
            <session_timeout_ms>10000</session_timeout_ms>
            <!-- Small cache threshold so entries quickly spill to disk log files. -->
            <latest_logs_cache_size_threshold>10000</latest_logs_cache_size_threshold>
            <commit_logs_cache_size_threshold>10000</commit_logs_cache_size_threshold>
            <!-- Rotate every 1000 entries to produce multiple sealed files. -->
            <rotate_log_storage_interval>1000</rotate_log_storage_interval>
            <!-- Snapshot rarely so the catching-up follower must replay from log. -->
            <snapshot_distance>100000</snapshot_distance>
            <raft_logs_level>information</raft_logs_level>
            <compress_logs>false</compress_logs>
            <!-- Enable read-ahead for the catch-up path. -->
            <keeper_log_readahead_enabled>true</keeper_log_readahead_enabled>
            <keeper_log_readahead_window_bytes>67108864</keeper_log_readahead_window_bytes>
            <keeper_log_readahead_max_peer_readers>4</keeper_log_readahead_max_peer_readers>
        </coordination_settings>

        <raft_configuration>
            <server>
                <id>1</id>
                <hostname>node1</hostname>
                <port>9234</port>
                <can_become_leader>true</can_become_leader>
                <priority>3</priority>
            </server>
            <server>
                <id>2</id>
                <hostname>node2</hostname>
                <port>9234</port>
                <can_become_leader>true</can_become_leader>
                <start_as_follower>true</start_as_follower>
                <priority>2</priority>
            </server>
            <server>
                <id>3</id>
                <hostname>node3</hostname>
                <port>9234</port>
                <can_become_leader>true</can_become_leader>
                <start_as_follower>true</start_as_follower>
                <priority>1</priority>
            </server>
        </raft_configuration>
    </keeper_server>
</clickhouse>
