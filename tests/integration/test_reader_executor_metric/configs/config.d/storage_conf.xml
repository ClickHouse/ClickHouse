<clickhouse>
    <storage_configuration>
        <disks>
            <disk_s3>
                <type>s3</type>
                <endpoint>http://minio1:9001/root/data/disks/reader_executor_metric/</endpoint>
                <access_key_id>minio</access_key_id>
                <secret_access_key>ClickHouse_Minio_P@ssw0rd</secret_access_key>
            </disk_s3>
            <!-- Cache layer at production geometry (32 MiB segments, 4 MiB alignment).
                 cache_on_write_operations=0 so INSERT does not warm the cache; reads
                 alone populate it, which lets the test control the cache state. -->
            <disk_cache>
                <type>cache</type>
                <disk>disk_s3</disk>
                <path>/disk_cache/</path>
                <max_size>10Gi</max_size>
                <max_file_segment_size>32Mi</max_file_segment_size>
                <boundary_alignment>4Mi</boundary_alignment>
                <cache_on_write_operations>0</cache_on_write_operations>
            </disk_cache>
        </disks>
        <policies>
            <s3_cache>
                <volumes>
                    <main>
                        <disk>disk_cache</disk>
                    </main>
                </volumes>
            </s3_cache>
        </policies>
    </storage_configuration>
</clickhouse>
