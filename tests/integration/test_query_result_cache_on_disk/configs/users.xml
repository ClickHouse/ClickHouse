<clickhouse>
    <profiles>
        <default>
        </default>
    </profiles>

    <users>
        <default>
            <password></password>
            <networks>
                <ip>::/0</ip>
            </networks>
            <profile>default</profile>
            <quota>default</quota>
            <access_management>1</access_management>
            <named_collection_control>1</named_collection_control>
        </default>

        <!-- A second user, used to verify that an on-disk query cache entry written by `default`
             (a per-user, non-shared entry) is not readable by another user after a restart. -->
        <other>
            <password></password>
            <networks>
                <ip>::/0</ip>
            </networks>
            <profile>default</profile>
            <quota>default</quota>
        </other>
    </users>

    <quotas>
        <default>
        </default>
    </quotas>
</clickhouse>
