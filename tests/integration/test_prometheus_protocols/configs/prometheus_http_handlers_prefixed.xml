<clickhouse>
    <http_handlers>
        <rule>
            <url>/prometheus/api/v1/write</url>
            <handler>
                <type>remote_write</type>
                <table>default.prometheus</table>
            </handler>
        </rule>
        <rule>
            <url>/prometheus/api/v1/read</url>
            <handler>
                <type>remote_read</type>
                <table>default.prometheus</table>
            </handler>
        </rule>
        <rule>
            <url>/prometheus/api/v1/query_range</url>
            <handler>
                <type>query_api</type>
                <table>default.prometheus</table>
            </handler>
        </rule>
        <rule>
            <url>/prometheus/api/v1/query</url>
            <handler>
                <type>query_api</type>
                <table>default.prometheus</table>
            </handler>
        </rule>
        <rule>
            <url>/api/v1/write</url>
            <handler>
                <type>remote_write</type>
                <table>default.prometheus</table>
            </handler>
        </rule>
        <rule>
            <url>/api/v1/read</url>
            <handler>
                <type>remote_read</type>
                <table>default.prometheus</table>
            </handler>
        </rule>
        <rule>
            <url>/api/v1/query</url>
            <handler>
                <type>query_api</type>
                <table>default.prometheus</table>
            </handler>
        </rule>
        <defaults/>
    </http_handlers>
</clickhouse>
