<clickhouse>
    <!--
        Regression coverage for `prometheus.http_path_prefix = "/"` (root mount).

        With the root prefix, Prometheus protocols must be reachable at:
            /write?database=...&table=...
            /read?database=...&table=...
            /api/v1/{query,query_range,series,labels,...}?database=...&table=...

        i.e. with a SINGLE leading slash before `write`, `read`, or `api`. Earlier the route
        regex incorrectly required extra path segments, which made the root mount unreachable.
        See `addPrometheusProtocolsToHTTPDefaults`.
    -->
    <prometheus>
        <http_path_prefix>/</http_path_prefix>
    </prometheus>
</clickhouse>
