<clickhouse>
    <profiles>
        <default>
            <!-- The STS Glue tests authenticate the catalog with aws_role_arn and no explicit keys. A Glue
                 catalog is built once with the global server context, so a per-query setting cannot reach it;
                 the value must come from the default profile. Allow server-managed credentials here. -->
            <s3_allow_server_credentials_in_user_queries>1</s3_allow_server_credentials_in_user_queries>
        </default>
    </profiles>
</clickhouse>
