<clickhouse>
    <keeper_server>
        <use_cluster>false</use_cluster>
        <tcp_port>9181</tcp_port>
        <server_id>3</server_id>
        <log_storage_path>/var/lib/clickhouse/coordination/log</log_storage_path>
        <snapshot_storage_path>/var/lib/clickhouse/coordination/snapshots</snapshot_storage_path>
        <!-- Do not snapshot on exit, so that after a restart the on-disk logs
             are not covered by a snapshot and have to be preprocessed again
             (localLogsPreprocessed() == false during startup). -->
        <create_snapshot_on_exit>false</create_snapshot_on_exit>

        <coordination_settings>
            <operation_timeout_ms>5000</operation_timeout_ms>
            <session_timeout_ms>10000</session_timeout_ms>
            <!-- Large enough that the workload below never triggers a snapshot. -->
            <snapshot_distance>100000</snapshot_distance>
            <reserved_log_items>1000000</reserved_log_items>
            <force_sync>true</force_sync>
            <!-- The streaming + async + new dispatcher combination is what enables
                 the pipelined parallel-log-appending path in handle_append_entries.
                 nuraft_max_log_gap_in_stream MUST be > 0: that is what makes the
                 leader set ALLOW_ASYNC_LOG_APPENDING on append_entries, which in
                 turn makes the follower take the async (deferred-response) path.
                 It defaults to 0, which disables this path entirely. -->
            <async_replication>true</async_replication>
            <nuraft_streaming_mode>true</nuraft_streaming_mode>
            <nuraft_max_log_gap_in_stream>100000</nuraft_max_log_gap_in_stream>
            <nuraft_max_bytes_in_flight_in_stream>1000000000</nuraft_max_bytes_in_flight_in_stream>
            <use_new_dispatcher>true</use_new_dispatcher>
            <raft_logs_level>information</raft_logs_level>
            <compress_logs>false</compress_logs>
        </coordination_settings>

        <raft_configuration>
            <server>
                <id>1</id>
                <hostname>node1</hostname>
                <port>9234</port>
                <can_become_leader>true</can_become_leader>
                <priority>3</priority>
            </server>
            <server>
                <id>2</id>
                <hostname>node2</hostname>
                <port>9234</port>
                <can_become_leader>true</can_become_leader>
                <priority>1</priority>
            </server>
            <server>
                <id>3</id>
                <hostname>node3</hostname>
                <port>9234</port>
                <can_become_leader>true</can_become_leader>
                <priority>2</priority>
            </server>
        </raft_configuration>
    </keeper_server>
</clickhouse>
