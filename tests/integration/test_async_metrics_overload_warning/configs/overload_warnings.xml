<clickhouse>
    <!-- Disable the periodic asynchronous-metrics refresh (very large period) so that only the
         synchronous update performed once at server startup has run by the time the test queries
         system.warnings. This makes the first-cycle behaviour observable deterministically. -->
    <asynchronous_metrics_update_period_s>60000</asynchronous_metrics_update_period_s>
    <asynchronous_heavy_metrics_update_period_s>60000</asynchronous_heavy_metrics_update_period_s>

    <!-- Make the memory-overload warning fire unconditionally on the very first cycle:
         any non-negative memory usage ratio is >= 0, and there is no minimum duration. -->
    <resource_overload_warnings>
        <memory_overload_warn_ratio>0.0</memory_overload_warn_ratio>
        <memory_overload_clear_ratio>0.0</memory_overload_clear_ratio>
        <memory_overload_duration_seconds>0</memory_overload_duration_seconds>
    </resource_overload_warnings>
</clickhouse>
