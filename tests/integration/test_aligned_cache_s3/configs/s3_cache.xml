<clickhouse>
    <storage_configuration>
        <disks>
            <disk_s3>
                <type>s3</type>
                <endpoint>http://minio1:9001/root/data/disks/disk_s3/</endpoint>
                <access_key_id>minio</access_key_id>
                <secret_access_key>ClickHouse_Minio_P@ssw0rd</secret_access_key>
            </disk_s3>
            <aligned_cache>
                <type>cache</type>
                <disk>disk_s3</disk>
                <path>/tmp/s3_aligned_cache/</path>
                <max_size>1Gi</max_size>
                <use_real_disk_size>1</use_real_disk_size>
            </aligned_cache>
            <!-- An encrypted disk on top of a cache with `use_real_disk_size` writes a tiny
                 (sub-block) header file during `checkAccess` at startup, which exercises a
                 cache reservation whose disk-accounted delta is zero. -->
            <aligned_cache_encrypted>
                <type>encrypted</type>
                <disk>aligned_cache</disk>
                <key>1234567812345678</key>
            </aligned_cache_encrypted>
        </disks>
        <policies>
            <external>
                <volumes>
                    <main>
                        <disk>aligned_cache</disk>
                    </main>
                </volumes>
            </external>
            <external_encrypted>
                <volumes>
                    <main>
                        <disk>aligned_cache_encrypted</disk>
                    </main>
                </volumes>
            </external_encrypted>
        </policies>
    </storage_configuration>
</clickhouse>
