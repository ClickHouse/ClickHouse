<clickhouse>
    <!--
        Negative case: a `static` HTTP handler references `config://missing_payload.suffix`, but the
        top-level `<missing_payload>` section has no `<suffix>` child, so the full referenced path
        `missing_payload.suffix` does not exist. `StaticRequestHandler` reads it with
        `getRawString("missing_payload.suffix", "Ok.\n")`, serving the default `Ok.\n` and never
        consuming `<missing_payload>`. The unknown-key validator must NOT exempt the top-level
        `<missing_payload>` just because a `config://` value names it: the unread section is a genuine
        unknown key (a typo), so the node must fail to start with `UNKNOWN_ELEMENT_IN_CONFIG`.
    -->
    <missing_payload>This is never read; its suffix child does not exist.</missing_payload>

    <http_handlers>
        <rule>
            <methods>GET</methods>
            <url>/static_missing_path</url>
            <handler>
                <type>static</type>
                <response_content>config://missing_payload.suffix</response_content>
            </handler>
        </rule>
        <defaults/>
    </http_handlers>
</clickhouse>
