<clickhouse>
    <query_cache replace="replace">
        <type>redis</type>
        <allow_experimental_remote_query_result_cache>true</allow_experimental_remote_query_result_cache>
        <redis>
            <host>redis1</host>
            <port>6379</port>
            <password>clickhouse</password>
            <db_index>0</db_index>
            <pool_size>4</pool_size>
            <connect_timeout_ms>1000</connect_timeout_ms>
            <receive_timeout_ms>1000</receive_timeout_ms>
            <max_retries>1</max_retries>
            <retry_delay_ms>50</retry_delay_ms>
            <!-- Fixed-TTL advisory lease (not renewed): bounds the stampede-protection window.
                 A query slower than this is still cached on completion. -->
            <lock_ttl_ms>5000</lock_ttl_ms>
            <lock_poll_interval_ms>100</lock_poll_interval_ms>
            <lock_max_wait_ms>5000</lock_max_wait_ms>
        </redis>
        <!-- small limits to exercise size guards -->
        <max_entry_size_in_bytes>10485760</max_entry_size_in_bytes>
        <max_entry_size_in_rows>1000000</max_entry_size_in_rows>
        <max_entries>2</max_entries>
    </query_cache>
</clickhouse>
