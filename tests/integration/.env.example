# Copy this file to .env and fill in the values for the e2e tests you want to run.
# Variables for backends you don't need can be left empty — those backends will be skipped.
#
# Load order: conftest.py loads .env with override=False, so environment variables
# already set in the shell take precedence over this file.

# ── AWS (Glue catalog + S3 Iceberg storage) ───────────────────────────────────
# Used by: test_e2e_catalogs (glue backend), test_e2e_iceberg_tf (s3 backend)
E2E_AWS_REGION=us-east-1
E2E_AWS_S3_BUCKET=
E2E_AWS_S3_PREFIX=clickhouse-e2e-iceberg-s3
E2E_AWS_ACCESS_KEY_ID=
E2E_AWS_SECRET_ACCESS_KEY=

# ── Microsoft OneLake ─────────────────────────────────────────────────────────
# Used by: test_e2e_catalogs (onelake backend)
E2E_ONELAKE_TENANT_ID=
E2E_ONELAKE_CLIENT_ID=
E2E_ONELAKE_CLIENT_SECRET=
E2E_ONELAKE_WORKSPACE_ID=
E2E_ONELAKE_LAKEHOUSE_ID=

# ── Azure Blob Storage (Iceberg storage) ──────────────────────────────────────
# Used by: test_e2e_iceberg_tf (azure backend)
E2E_ICEBERG_AZURE_ACCOUNT_NAME=
E2E_ICEBERG_AZURE_ACCOUNT_KEY=
E2E_ICEBERG_AZURE_CONTAINER_NAME=

# ── Google BigLake ────────────────────────────────────────────────────────────
# Used by: test_e2e_catalogs (biglake backend)
E2E_GCP_PROJECT=
E2E_GCP_BUCKET=
E2E_BIGLAKE_ADC_CLIENT_ID=
E2E_BIGLAKE_ADC_CLIENT_SECRET=
E2E_BIGLAKE_ADC_REFRESH_TOKEN=
E2E_BIGLAKE_GCS_PREFIX=
