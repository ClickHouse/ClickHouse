<clickhouse>
    <!--
        Disable all system logs in this compatibility test.

        The new server marks rotated system log tables (e.g. `query_log_0`) with
        the `table_readonly` MergeTree setting, which is persisted into the table
        metadata. An older server started via `restart_with_original_version` does
        not know this setting and would fail to attach such tables on startup.

        This test only exercises user tables, so we disable system logs entirely
        to avoid creating any system log table that could be rotated and then fail
        to load on the older binary.
    -->
    <aggregated_zookeeper_log remove="remove"/>
    <asynchronous_insert_log remove="remove"/>
    <asynchronous_metric_log remove="remove"/>
    <azure_queue_log remove="remove"/>
    <background_schedule_pool_log remove="remove"/>
    <backup_log remove="remove"/>
    <blob_storage_log remove="remove"/>
    <crash_log remove="remove"/>
    <delta_lake_metadata_log remove="remove"/>
    <error_log remove="remove"/>
    <filesystem_cache_log remove="remove"/>
    <filesystem_read_prefetches_log remove="remove"/>
    <iceberg_metadata_log remove="remove"/>
    <instrumentation_trace_log remove="remove"/>
    <latency_log remove="remove"/>
    <metric_log remove="remove"/>
    <opentelemetry_span_log remove="remove"/>
    <part_log remove="remove"/>
    <processors_profile_log remove="remove"/>
    <query_condition_cache_log remove="remove"/>
    <query_log remove="remove"/>
    <query_metric_log remove="remove"/>
    <query_thread_log remove="remove"/>
    <query_views_log remove="remove"/>
    <s3queue_log remove="remove"/>
    <session_log remove="remove"/>
    <text_log remove="remove"/>
    <trace_log remove="remove"/>
    <transactions_info_log remove="remove"/>
    <zookeeper_connection_log remove="remove"/>
    <zookeeper_log remove="remove"/>
</clickhouse>
