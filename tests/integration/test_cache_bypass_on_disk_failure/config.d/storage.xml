<clickhouse>
    <storage_configuration>
        <disks>
            <s3_disk>
                <type>object_storage</type>
                <object_storage_type>s3</object_storage_type>
                <metadata_type>plain_rewritable</metadata_type>
                <endpoint>http://minio1:9001/root/data/</endpoint>
                <access_key_id>minio</access_key_id>
                <secret_access_key>ClickHouse_Minio_P@ssw0rd</secret_access_key>
            </s3_disk>
            <cache_disk_skip>
                <type>cache</type>
                <disk>s3_disk</disk>
                <path>/var/lib/clickhouse/cache_skip/</path>
                <max_size>10Gi</max_size>
                <skip_cache_on_disk_failure>1</skip_cache_on_disk_failure>
            </cache_disk_skip>
            <cache_disk_noskip>
                <type>cache</type>
                <disk>s3_disk</disk>
                <path>/var/lib/clickhouse/cache_noskip/</path>
                <max_size>10Gi</max_size>
                <skip_cache_on_disk_failure>0</skip_cache_on_disk_failure>
            </cache_disk_noskip>
        </disks>
        <policies>
            <s3_cache_skip>
                <volumes>
                    <main>
                        <disk>cache_disk_skip</disk>
                    </main>
                </volumes>
            </s3_cache_skip>
            <s3_cache_noskip>
                <volumes>
                    <main>
                        <disk>cache_disk_noskip</disk>
                    </main>
                </volumes>
            </s3_cache_noskip>
        </policies>
    </storage_configuration>
</clickhouse>
