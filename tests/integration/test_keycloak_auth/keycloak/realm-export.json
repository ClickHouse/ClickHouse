{
  "realm": "clickhouse-test",
  "enabled": true,
  "sslRequired": "none",
  "registrationAllowed": false,
  "clients": [
    {
      "clientId": "clickhouse",
      "enabled": true,
      "secret": "test-secret",
      "publicClient": false,
      "directAccessGrantsEnabled": true,
      "serviceAccountsEnabled": false,
      "standardFlowEnabled": true,
      "attributes": {
        "oauth2.device.authorization.grant.enabled": "true"
