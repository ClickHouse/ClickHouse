      "lastName": "Tester",
      "requiredActions": [],
      "credentials": [
        {
          "type": "password",
          "value": "secret",
          "temporary": false
        }
      ],
      "realmRoles": ["offline_access", "uma_authorization", "default-roles-clickhouse-test"],
      "groups": ["analysts"]
    }
  ],
  "groups": [
    {
      "name": "analysts"
    }
  ]
