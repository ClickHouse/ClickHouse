<?xml version="1.0"?>
<!--
    Simulate an on-prem deployment that puts static S3 credentials in the
    top-level <s3> config block. Before the hardening fix, a user-supplied
    `role_arn` would silently be signed with these credentials (privilege
    escalation). After the fix, the server must reject any user `role_arn`
    that is not paired with user-supplied `access_key_id` and
    `secret_access_key` in the same SQL scope.
-->
<clickhouse>
    <s3>
        <access_key_id>ADMIN_FAKE_KEY</access_key_id>
        <secret_access_key>ADMIN_FAKE_SECRET</secret_access_key>
        <header>X-Admin-Secret: ADMIN_HEADER</header>
        <trusted_endpoint>
            <endpoint>http://resolver:18080/trusted/</endpoint>
            <access_key_id>TRUSTED_FAKE_KEY</access_key_id>
            <secret_access_key>TRUSTED_FAKE_SECRET</secret_access_key>
            <header>X-Admin-Secret: TRUSTED_HEADER</header>
        </trusted_endpoint>
        <trusted_path_boundary_endpoint>
            <endpoint>http://resolver:18080/path_boundary</endpoint>
            <access_key_id>TRUSTED_FAKE_KEY</access_key_id>
            <secret_access_key>TRUSTED_FAKE_SECRET</secret_access_key>
        </trusted_path_boundary_endpoint>
        <backup_public_endpoint>
            <endpoint>http://minio1:9001/root/backup_public/</endpoint>
            <header>X-Revoked-Endpoint-Header: TRUSTED_HEADER</header>
        </backup_public_endpoint>
        <backup_gcp_oauth_partial_adc_endpoint>
            <endpoint>http://minio1:9001/root/backup_gcp_oauth_partial_adc/</endpoint>
            <http_client>gcp_oauth</http_client>
            <google_adc_client_id>ADC_CLIENT_ID</google_adc_client_id>
        </backup_gcp_oauth_partial_adc_endpoint>
        <backup_session_token_endpoint>
            <endpoint>http://resolver:18080/backup_session_token/</endpoint>
            <access_key_id>TEMP_FAKE_KEY</access_key_id>
            <secret_access_key>TEMP_FAKE_SECRET</secret_access_key>
            <session_token>TRUSTED_SESSION_TOKEN</session_token>
        </backup_session_token_endpoint>
        <backup_access_header_endpoint>
            <endpoint>http://resolver:18080/backup_access_header/</endpoint>
            <use_environment_credentials>false</use_environment_credentials>
            <access_header>X-Backup-Access: TRUSTED_ACCESS_HEADER</access_header>
        </backup_access_header_endpoint>
    </s3>
</clickhouse>
