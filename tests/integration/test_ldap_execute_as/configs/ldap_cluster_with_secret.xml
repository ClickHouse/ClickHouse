<clickhouse>
    <ldap_servers>
        <openldap>
            <host>openldap</host>
            <port>1389</port>
            <bind_dn>cn={user_name},ou=users,dc=example,dc=org</bind_dn>
            <enable_tls>no</enable_tls>
            <!-- Service-bind credentials so the forced lookup that refreshes a
                 poisoned cache entry (see test
                 `test_execute_as_refreshes_distributed_cache_poisoned_entry`)
                 can resolve the user without a real password. -->
            <lookup_bind_dn>cn=admin,dc=example,dc=org</lookup_bind_dn>
            <lookup_password>clickhouse</lookup_password>
            <user_dn_detection>
                <base_dn>ou=users,dc=example,dc=org</base_dn>
                <search_filter>(&amp;(objectClass=person)(cn={user_name}))</search_filter>
            </user_dn_detection>
        </openldap>
    </ldap_servers>
    <user_directories>
        <ldap>
            <server>openldap</server>
            <role_mapping>
                <base_dn>dc=example,dc=org</base_dn>
                <scope>subtree</scope>
                <search_filter>(&amp;(objectClass=groupOfNames)(member={bind_dn}))</search_filter>
                <attribute>cn</attribute>
                <prefix>clickhouse-</prefix>
            </role_mapping>
        </ldap>
    </user_directories>
    <!-- Two-shard cluster configured with `<secret>foo</secret>` so the
         interserver protocol authenticates remote queries via
         `AlwaysAllowCredentials{initial_user}`. The shard receiving the
         remote half of an `EXECUTE AS <ldap_user> ... FROM clusterAllReplicas(...)`
         goes through `LDAPAccessStorage::authenticateImpl` with
         `AlwaysAllowCredentials`, which short-circuits role resolution and
         leaves the cache entry with empty `users_external_roles`. The
         regression test then runs a local `EXECUTE AS` on that shard and
         verifies the role mapping was refreshed (without the fix the local
         `EXECUTE AS` would inherit only the common roles). -->
    <remote_servers>
        <ldap_cluster>
            <secret>foo</secret>
            <node>
                <host>shard1_node</host>
                <port>9000</port>
            </node>
            <node>
                <host>shard2_node</host>
                <port>9000</port>
            </node>
        </ldap_cluster>
    </remote_servers>
</clickhouse>
