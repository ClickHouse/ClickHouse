<clickhouse>
    <ldap_servers>
        <openldap>
            <host>openldap</host>
            <port>1389</port>
            <bind_dn>cn={user_name},ou=users,dc=example,dc=org</bind_dn>
            <enable_tls>no</enable_tls>
            <!-- Deliberately wrong (but non-empty) `lookup_password`. The directory
                 will reject the service bind with `LDAP_INVALID_CREDENTIALS`. This
                 must produce a configuration error, not the canonical `UNKNOWN_USER`
                 path, so that operators can tell "the lookup account is broken" apart
                 from "the target user does not exist". -->
            <lookup_bind_dn>cn=admin,dc=example,dc=org</lookup_bind_dn>
            <lookup_password>this_password_is_wrong</lookup_password>
            <user_dn_detection>
                <base_dn>ou=users,dc=example,dc=org</base_dn>
                <search_filter>(&amp;(objectClass=person)(cn={user_name}))</search_filter>
            </user_dn_detection>
        </openldap>
    </ldap_servers>
    <user_directories>
        <ldap>
            <server>openldap</server>
        </ldap>
    </user_directories>
</clickhouse>
