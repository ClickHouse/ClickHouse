<clickhouse>
    <keeper_server>
        <tcp_port>9181</tcp_port>
        <server_id>2</server_id>

        <coordination_settings>
            <operation_timeout_ms>5000</operation_timeout_ms>
            <session_timeout_ms>10000</session_timeout_ms>
            <raft_logs_level>trace</raft_logs_level>
            <snapshot_distance>50</snapshot_distance>
            <snapshots_to_keep>1</snapshots_to_keep>
            <stale_log_gap>10</stale_log_gap>
            <reserved_log_items>1</reserved_log_items>
            <snapshot_transfer_chunk_size>4096</snapshot_transfer_chunk_size>
        </coordination_settings>

        <raft_configuration>
            <server>
                <id>1</id>
                <hostname>node1</hostname>
                <port>9234</port>
                <priority>70</priority>
            </server>
            <server>
                <id>2</id>
                <hostname>node2</hostname>
                <port>9234</port>
                <priority>20</priority>
                <start_as_follower>true</start_as_follower>
            </server>
            <server>
                <id>3</id>
                <hostname>node3</hostname>
                <port>9234</port>
                <priority>10</priority>
                <start_as_follower>true</start_as_follower>
            </server>
        </raft_configuration>
    </keeper_server>
</clickhouse>
