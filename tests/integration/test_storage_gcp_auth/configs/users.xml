<clickhouse>
    <profiles>
        <default>
            <enable_s3_requests_logging>1</enable_s3_requests_logging>
            <!-- This test uses `gcp_oauth` named collections that authenticate via the GCP metadata
                 service, which is server-managed and blocked for user queries by default. Allow it here. -->
            <s3_allow_server_credentials_in_user_queries>1</s3_allow_server_credentials_in_user_queries>
        </default>
    </profiles>
    <users>
        <default>
            <password></password>
            <profile>default</profile>
            <named_collection_control>1</named_collection_control>
        </default>
    </users>
</clickhouse>
