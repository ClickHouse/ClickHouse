<clickhouse>
    <profiles>
        <default/>
        <my.profile>
            <max_memory_usage>10000000</max_memory_usage>
        </my.profile>
    </profiles>
    <users>
        <default>
            <password/>
            <networks>
                <ip>::/0</ip>
            </networks>
            <profile>default</profile>
            <quota>default</quota>
        </default>
        <user.name>
            <password/>
            <networks>
                <ip>::/0</ip>
            </networks>
            <profile>default</profile>
            <quota>default</quota>
        </user.name>
        <dotted.user>
            <password/>
            <networks>
                <ip>::/0</ip>
            </networks>
            <profile>my.profile</profile>
            <quota>my.quota</quota>
            <grants>
                <query>GRANT `my.role`</query>
                <query>GRANT SELECT ON default.test_row_policy</query>
            </grants>
            <databases>
                <default>
                    <test_row_policy>
                        <filter>x = 1</filter>
                    </test_row_policy>
                </default>
            </databases>
        </dotted.user>
    </users>
    <roles>
        <my.role>
            <grants>
                <query>GRANT SELECT ON system.numbers</query>
            </grants>
        </my.role>
    </roles>
    <quotas>
        <default/>
        <my.quota>
            <interval>
                <duration>3600</duration>
                <queries>100</queries>
            </interval>
        </my.quota>
    </quotas>
</clickhouse>
