<clickhouse>
    <logger>
        <level>trace</level>
        <size>1000M</size>
        <count>10</count>
    </logger>

    <tcp_port>9090</tcp_port>
    <!-- <tcp_with_proxy_port>9091</tcp_with_proxy_port> -->

    <!-- Upstream ClickHouse servers, declared as named clusters of replicas. -->
    <upstreams>
        <clusters>
            <cluster_a>
                <replica>
                    <host>127.0.0.1</host>
                    <!-- port with enabled proxy header parsing -->
                    <tcp_port>9011</tcp_port>
                </replica>
            </cluster_a>
            <cluster_b>
                <replica>
                    <host>127.0.0.1</host>
                    <tcp_port>9011</tcp_port>
                </replica>
                <replica>
                    <host>127.0.0.1</host>
                    <tcp_port>9012</tcp_port>
                </replica>
            </cluster_b>
        </clusters>
    </upstreams>

    <routing>
        <rules>
            <rule>
                <user>admin</user>
                <action>
                    <route_to>cluster_b</route_to>
                </action>
            </rule>
            <rule>
                <database>test_database</database>
                <!-- <host>test.clickhouse.cloud</host> -->
                <user>test_user</user>
                <action>
                    <route_to>cluster_a</route_to>
                </action>
            </rule>
            <rule>
                <user>test_user</user>
                <!-- <host>test-1.clickhouse.cloud</host> -->
                <action>
                    <route_to>cluster_b</route_to>
                    <policy>round_robin</policy>
                </action>
            </rule>
            <rule>
                <database>deprecated_database</database>
                <!-- <host>test.clickhouse.cloud</host> -->
                <action>
                    <reject>true</reject>
                </action>
            </rule>
        </rules>
        <default>
             <action>
                <reject>true</reject>
            </action>
        </default>
    </routing>
</clickhouse>
