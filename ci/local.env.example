# Local CI environment overrides.
# Copy this file to ci/local.env (gitignored) and set values as needed.
# Variables defined here are exported to the environment before any CI job stage runs.
# Example: use a private sccache S3 bucket for local builds.

# SCCACHE_ENDPOINT=https://my-s3-endpoint.com
# SCCACHE_BUCKET=my-sccache-bucket
# AWS_ACCESS_KEY_ID=...
# AWS_SECRET_ACCESS_KEY=...
