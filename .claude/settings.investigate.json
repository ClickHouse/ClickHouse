    "deny": [
      "Edit",
      "Write",
      "NotebookEdit",
      "Bash(git push:*)",
      "Bash(git commit:*)",
      "Bash(git add:*)",
      "Bash(git reset:*)",
      "Bash(git rebase:*)",
      "Bash(git merge:*)",
      "Bash(git checkout:*)",
      "Bash(git switch:*)",
      "Bash(git restore:*)",
      "Bash(git clean:*)",
      "Bash(git stash:*)",
      "Bash(git branch:*)",
      "Bash(git tag:*)",
      "Bash(git rm:*)",
      "Bash(git mv:*)",
      "Bash(rm:*)",
      "Bash(mv:*)",
      "Bash(gh pr create:*)",
      "Bash(gh pr merge:*)",
      "Bash(gh pr close:*)",
      "Bash(gh pr edit:*)",
      "Bash(gh pr comment:*)",
      "Bash(gh pr review:*)",
      "Bash(gh issue create:*)",
      "Bash(gh issue close:*)",
      "Bash(gh issue edit:*)",
      "Bash(gh issue comment:*)",
      "Bash(gh api:*)"
    ],
    "allow": [
      "Bash(node .claude/tools/fetch_ci_report.js:*)",
      "Bash(python3 .claude/tools/fetch_perf_report.py:*)",
      "Bash(python3 .claude/tools/analyze-assembly.py:*)",
      "Bash(curl -sS https://play.clickhouse.com/?user=play:*)",
      "Bash(tar -xzf:*)",
      "Bash(tar -xf:*)",
      "Bash(tar -tzf:*)",
      "Bash(grep:*)",
      "Bash(jq:*)",
      "Bash(ls:*)",
      "Bash(cat:*)",
      "Bash(head:*)",
      "Bash(tail:*)",
      "Bash(wc:*)",
      "Bash(gh pr view:*)",
      "Bash(gh pr diff:*)",
      "Bash(gh pr list:*)",
      "Bash(gh pr checks:*)",
      "Bash(gh issue view:*)",
      "Bash(gh issue list:*)",
      "Bash(git log:*)",
      "Bash(git show:*)",
      "Bash(git status)",
      "Bash(git diff:*)",
      "WebFetch(domain:play.clickhouse.com)",
      "WebFetch(domain:s3.amazonaws.com)",
      "WebFetch(domain:github.com)"
    ]
  }
